---
import Logo from './Logo.astro';
import { settings as mockSettings } from '../data/mockData.js';
import { sanityClient, SETTINGS_QUERY, dataAttribute, cleanStega } from '../lib/sanity.js';

let settings = mockSettings;
try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings in Footer component:", e);
}

const footerPagesLinks = settings.footerPagesLinks && settings.footerPagesLinks.length > 0
  ? settings.footerPagesLinks
  : [
      { label: 'Accueil Optique', path: '/' },
      { label: 'Les Collections', path: '/collections' },
      { label: 'Prestations & Savoir', path: '/services' },
      { label: 'Atelier & Plan', path: '/boutique' },
      { label: 'Contacter / RDV', path: '/contact' }
    ];

const footerLegalLinks = settings.footerLegalLinks && settings.footerLegalLinks.length > 0
  ? settings.footerLegalLinks
  : [
      { label: 'Mentions Légales', path: '#' },
      { label: 'Politique de Confidentialité', path: '#' }
    ];

const socialLinks = settings.socialLinks && settings.socialLinks.length > 0
  ? settings.socialLinks
  : settings.instagram
    ? [{ _key: 'default-instagram', platform: 'instagram', url: settings.instagram }]
    : [{ _key: 'default-instagram', platform: 'instagram', url: 'https://www.instagram.com/alexsee.avron/' }];

const currentYear = new Date().getFullYear();
---

<footer id="app-global-footer" class="bg-optical-black text-ivory pt-24 pb-12 px-6 md:px-12 lg:px-24 border-t border-stone-grey/20 relative w-full overflow-hidden">
  <div 
    data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerBackgroundText' }) : undefined}
    class="opacity-5 font-bold tracking-widest uppercase text-[15vw] leading-none select-none pointer-events-none absolute bottom-0 left-0 right-0 text-center font-display"
  >
    {settings.footerBackgroundText || "AlexSEE"}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 relative z-10 mb-16 border-b border-stone-grey/15 pb-16">
    <div class="col-span-1 md:col-span-4 space-y-4">
      <Logo size="md" showText={true} inverse={true} class="items-start text-left" />
      <p 
        data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerDescription' }) : undefined} 
        class="text-stone-grey max-w-xs text-xs font-light leading-relaxed"
      >
        {settings.footerDescription || "Opticien créateur indépendant au cœur du 20e arrondissement parisien. Un regard différent sur la lunetterie."}
      </p>
      <div class="pt-2 flex gap-4" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'socialLinks' }) : undefined}>
        {socialLinks.map((social) => {
          const cleanUrl = cleanStega(social.url) || "#";
          const platform = cleanStega(social.platform) || "website";
          return (
            <a 
              href={cleanUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              data-sanity={settings._id ? (social._key && social._key !== 'default-instagram' ? dataAttribute({ id: settings._id, type: settings._type, path: `socialLinks[_key == "${social._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'socialLinks' })) : undefined}
              class="w-8 h-8 rounded-full border border-stone-grey/30 flex items-center justify-center text-stone-grey hover:text-cobalt hover:border-cobalt transition-colors" 
              aria-label={platform}
            >
              {platform === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              )}
              {platform === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              )}
              {platform === 'twitter' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
              )}
              {platform === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              )}
              {platform === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/><path d="m10 15 5-3-5-3z"/></svg>
              )}
              {platform === 'tiktok' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              )}
              {platform === 'website' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              )}
            </a>
          );
        })}
      </div>
    </div>

    <div class="col-span-1 md:col-span-3 space-y-4 font-mono text-xs uppercase tracking-widest">
      <span 
        data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerPagesTitle' }) : undefined}
        class="text-stone-grey text-[10px] block font-semibold mb-2"
      >
        {settings.footerPagesTitle || "[ Pages ]"}
      </span>
      <ul class="space-y-2.5" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerPagesLinks' }) : undefined}>
        {footerPagesLinks.map((link) => (
          <li data-sanity={settings._id ? (link._key ? dataAttribute({ id: settings._id, type: settings._type, path: `footerPagesLinks[_key == "${link._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'footerPagesLinks' })) : undefined}>
            <a href={link.path || "#"} class="hover:text-cobalt transition-colors text-stone-grey">{link.label || ""}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="col-span-1 md:col-span-5 space-y-4 font-mono text-xs uppercase tracking-widest">
      <span 
        data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerBoutiqueTitle' }) : undefined}
        class="text-stone-grey text-[10px] block font-semibold mb-2"
      >
        {settings.footerBoutiqueTitle || "[ Boutique ]"}
      </span>
      <ul class="space-y-2.5 text-stone-grey font-light">
        {settings.footerContactDetails && settings.footerContactDetails.length > 0 ? (
          settings.footerContactDetails.map((item) => (
            <li class="normal-case" data-sanity={settings._id ? (item._key ? dataAttribute({ id: settings._id, type: settings._type, path: `footerContactDetails[_key == "${item._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'footerContactDetails' })) : undefined}>
              <span class="text-ivory">{item.label} :</span>{" "}
              {item.linkUrl ? (
                <a href={item.linkUrl} class="hover:text-cobalt transition-colors font-bold text-ivory">
                  {item.value}
                </a>
              ) : (
                <span>{item.value}</span>
              )}
            </li>
          ))
        ) : (
          <li class="normal-case">
            <span class="text-ivory">Adresse :</span> 
            <span data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'address' }) : undefined}>
              {settings.address || "28 Rue d’Avron"}, {settings.postalCode || "75020"} {settings.city || "Paris"}
            </span>
          </li>
          <li>
            <span class="text-ivory">Métro :</span> 
            <span data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'metro' }) : undefined}>
              {settings.metro || "Buzenval (M9), Avron (M2)"}
            </span>
          </li>
          <li class="normal-case">
            <span class="text-ivory">Téléphone :</span> 
            <a 
              href={`tel:${cleanStega(settings.phone)}`} 
              data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'phone' }) : undefined}
              class="hover:text-cobalt transition-colors font-bold text-ivory"
            >
              {settings.phone}
            </a>
          </li>
          <li class="normal-case">
            <span class="text-ivory">Email :</span> 
            <span data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'email' }) : undefined}>
              {settings.email}
            </span>
          </li>
        )}
      </ul>
    </div>
  </div>

  <div class="flex flex-col md:flex-row items-center justify-between font-mono text-[9px] text-stone-grey uppercase tracking-widest relative z-10 gap-4">
    <span data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerCopyrightText' }) : undefined}>
      © {currentYear} {settings.name || "AlexSEE"}. {settings.footerCopyrightText || "Tous droits réservés."}
    </span>
    <div class="flex gap-6" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerLegalLinks' }) : undefined}>
      {footerLegalLinks.map((link) => (
        <a 
          href={link.path || "#"} 
          data-sanity={settings._id ? (link._key ? dataAttribute({ id: settings._id, type: settings._type, path: `footerLegalLinks[_key == "${link._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'footerLegalLinks' })) : undefined}
          class="hover:text-cobalt transition-colors cursor-pointer"
        >
          {link.label || ""}
        </a>
      ))}
      <span 
        data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'footerLocationText' }) : undefined}
        class="text-stone-grey/50"
      >
        {settings.footerLocationText || "Paris XX, France"}
      </span>
    </div>
  </div>
</footer>
