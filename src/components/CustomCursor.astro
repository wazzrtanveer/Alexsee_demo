<div 
  id="custom-cursor" 
  class="fixed top-0 left-0 pointer-events-none z-[999] -translate-x-1/2 -translate-y-1/2 rounded-full border border-cobalt/40 flex items-center justify-center opacity-0 transition-[width,height,background-color,opacity] duration-300 w-8 h-8 bg-transparent"
>
  {/* Inner cobalt dot */}
  <div 
    id="custom-cursor-dot" 
    class="rounded-full bg-cobalt w-1 h-1 transition-all duration-300"
  ></div>
  {/* Label */}
  <span 
    id="custom-cursor-label" 
    class="absolute text-[8px] font-mono tracking-[0.2em] text-cobalt uppercase text-center leading-tight max-w-[60px] opacity-0 scale-75 transition-all duration-300 pointer-events-none"
  ></span>
</div>

<script>
  function initCursor() {
    const cursor = document.getElementById('custom-cursor');
    const cursorDot = document.getElementById('custom-cursor-dot');
    const cursorLabel = document.getElementById('custom-cursor-label');

    if (!cursor || !cursorDot || !cursorLabel) return;

    // Detect touch devices
    const mediaQuery = window.matchMedia('(pointer: coarse)');
    if (mediaQuery.matches) {
      cursor.style.display = 'none';
      return;
    }

    let mouse = { x: -100, y: -100 };
    let pos = { x: -100, y: -100 };
    let isVisible = false;
    const LERP = 0.15; // smoothness factor

    const handleMouseMove = (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
      if (!isVisible) {
        isVisible = true;
        cursor.style.opacity = '1';
      }
    };

    const handleMouseEnter = () => {
      cursor.style.opacity = '1';
    };

    const handleMouseLeave = () => {
      cursor.style.opacity = '0';
    };

    window.addEventListener('mousemove', handleMouseMove);
    document.addEventListener('mouseenter', handleMouseEnter);
    document.addEventListener('mouseleave', handleMouseLeave);

    // Anim loop
    let animId;
    const tick = () => {
      pos.x += (mouse.x - pos.x) * LERP;
      pos.y += (mouse.y - pos.y) * LERP;
      cursor.style.left = `${pos.x}px`;
      cursor.style.top = `${pos.y}px`;
      animId = requestAnimationFrame(tick);
    };
    tick();

    // Event delegation for labels
    const setupLabels = () => {
      const targets = document.querySelectorAll('[data-cursor-label]');
      targets.forEach(target => {
        // Remove previous if any to avoid double listeners
        const overHandler = () => {
          const text = target.getAttribute('data-cursor-label') || '';
          cursor.style.width = '72px';
          cursor.style.height = '72px';
          cursor.style.backgroundColor = 'rgba(46,91,255,0.06)';
          cursorDot.style.opacity = '0.4';
          cursorLabel.textContent = text;
          cursorLabel.style.opacity = '1';
          cursorLabel.style.transform = 'scale(1)';
        };

        const outHandler = () => {
          cursor.style.width = '32px';
          cursor.style.height = '32px';
          cursor.style.backgroundColor = 'transparent';
          cursorDot.style.opacity = '1';
          cursorLabel.style.opacity = '0';
          cursorLabel.style.transform = 'scale(0.75)';
        };

        target.addEventListener('pointerover', overHandler);
        target.addEventListener('pointerout', outHandler);
      });
    };

    setupLabels();

    // Clean up function
    return () => {
      window.removeEventListener('mousemove', handleMouseMove);
      document.removeEventListener('mouseenter', handleMouseEnter);
      document.removeEventListener('mouseleave', handleMouseLeave);
      cancelAnimationFrame(animId);
    };
  }

  // Support view transitions
  let cleanup;
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = initCursor();
  });
</script>
