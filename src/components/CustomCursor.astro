<div 
  id="custom-cursor" 
  class="fixed top-0 left-0 pointer-events-none z-[999] rounded-full border border-cobalt/40 flex items-center justify-center w-8 h-8 bg-transparent transition-colors duration-300 opacity-0"
>
  <!-- Inner cobalt dot -->
  <div 
    id="custom-cursor-dot" 
    class="w-1.5 h-1.5 bg-cobalt rounded-full"
  ></div>
  <!-- Label -->
  <div 
    id="custom-cursor-label" 
    class="absolute left-10 bg-optical-black text-ivory text-[9px] tracking-widest font-mono py-1 px-2.5 uppercase whitespace-nowrap border border-stone-grey/20 rounded-none shadow-xl opacity-0 scale-[0.8] transition-all duration-300 pointer-events-none"
  ></div>
</div>

<script>
  function initCursor() {
    const cursor = document.getElementById('custom-cursor');
    const cursorLabel = document.getElementById('custom-cursor-label');

    if (!cursor || !cursorLabel) return;

    // Detect touch devices
    const mediaQuery = window.matchMedia('(pointer: coarse)');
    if (mediaQuery.matches) {
      cursor.style.display = 'none';
      return;
    }

    let mouse = { x: -100, y: -100 };
    let pos = { x: -100, y: -100 };
    let vel = { x: 0, y: 0 };
    let scale = 0.6;
    let velScale = 0;
    let isHovered = false;
    let isVisible = false;

    const stiffness = 450;
    const damping = 40;
    const mass = 0.5;

    const handleMouseMove = (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
      if (!isVisible) {
        isVisible = true;
        pos.x = mouse.x;
        pos.y = mouse.y;
        vel.x = 0;
        vel.y = 0;
        cursor.style.opacity = '1';
      }
    };

    const handleMouseEnter = () => {
      isVisible = true;
      cursor.style.opacity = '1';
    };

    const handleMouseLeave = () => {
      isVisible = false;
      cursor.style.opacity = '0';
    };

    const handleMouseOver = (e) => {
      const target = e.target.closest('[data-cursor-label]');
      if (target) {
        const text = target.getAttribute('data-cursor-label') || '';
        cursorLabel.textContent = text;
        isHovered = true;
        
        // Show label
        cursorLabel.classList.remove('opacity-0', 'scale-[0.8]');
        cursorLabel.classList.add('opacity-100', 'scale-100');
      } else {
        isHovered = false;
        
        // Hide label
        cursorLabel.classList.remove('opacity-100', 'scale-100');
        cursorLabel.classList.add('opacity-0', 'scale-[0.8]');
      }
    };

    window.addEventListener('mousemove', handleMouseMove);
    document.addEventListener('mouseenter', handleMouseEnter);
    document.addEventListener('mouseleave', handleMouseLeave);
    document.addEventListener('mouseover', handleMouseOver);

    // Anim loop
    let animId;
    let lastTime = performance.now();

    const tick = (now) => {
      let dt = (now - lastTime) / 1000;
      if (dt > 0.1) dt = 0.1; // cap to avoid spikes
      lastTime = now;

      // Spring integration sub-stepping
      const steps = 8;
      const subDt = dt / steps;
      
      const targetScale = isHovered ? 1.5 : 0.6;

      for (let i = 0; i < steps; i++) {
        // X position
        const fx = -stiffness * (pos.x - mouse.x) - damping * vel.x;
        const ax = fx / mass;
        vel.x += ax * subDt;
        pos.x += vel.x * subDt;

        // Y position
        const fy = -stiffness * (pos.y - mouse.y) - damping * vel.y;
        const ay = fy / mass;
        vel.y += ay * subDt;
        pos.y += vel.y * subDt;

        // Scale
        const fs = -stiffness * (scale - targetScale) - damping * velScale;
        const as = fs / mass;
        velScale += as * subDt;
        scale += velScale * subDt;
      }

      cursor.style.transform = `translate3d(${pos.x}px, ${pos.y}px, 0) translate(-50%, -50%) scale(${scale})`;
      
      if (isHovered) {
        cursor.style.backgroundColor = 'rgba(10, 59, 255, 0.08)';
      } else {
        cursor.style.backgroundColor = 'transparent';
      }

      animId = requestAnimationFrame(tick);
    };

    animId = requestAnimationFrame(tick);

    // Clean up function
    return () => {
      window.removeEventListener('mousemove', handleMouseMove);
      document.removeEventListener('mouseenter', handleMouseEnter);
      document.removeEventListener('mouseleave', handleMouseLeave);
      document.removeEventListener('mouseover', handleMouseOver);
      cancelAnimationFrame(animId);
    };
  }

  // Support view transitions
  let cleanup;
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = initCursor();
  });
</script>
