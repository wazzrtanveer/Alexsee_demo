---
import Logo from './Logo.astro';
---

<div
  id="preloader"
  transition:persist
  class="fixed inset-0 text-ivory flex flex-col items-center justify-center overflow-hidden transition-opacity duration-600 ease-in-out"
  style="display: none; background-color: #0a0a0a; z-index: 99999;"
>
  <!-- Skip button -->
  <button
    id="preloader-skip"
    class="absolute top-8 right-8 font-mono text-[10px] uppercase tracking-widest text-stone-grey hover:text-ivory transition-colors duration-300 z-10 focus:outline-none pointer-events-auto"
  >
    [ Passer l'introduction / Skip ]
  </button>

  <!-- Relative container for elements -->
  <div class="relative flex flex-col items-center">
    <!-- Animated lens circle -->
    <div
      id="preloader-lens"
      class="absolute rounded-full w-96 h-96 border border-cobalt mix-blend-screen pointer-events-none animate-lens-in"
    ></div>

    <!-- Tagline (Slogan) - Placed ABOVE the logo container in original -->
    <p
      id="preloader-tagline"
      class="font-mono tracking-[0.25em] text-stone-grey text-[10px] uppercase text-center mb-6 animate-slogan-in"
    >
      Le regard comme expression personnelle — Paris XX
    </p>

    <!-- Logo container -->
    <div
      id="preloader-logo"
      class="flex flex-col items-center justify-center relative z-10 mt-4 animate-logo-in"
    >
      <Logo size="lg" inverse={true} showText={true} />
    </div>

    <!-- Bottom Badge -->
    <div
      id="preloader-badge"
      class="mt-10 flex items-center gap-2 animate-badge-in"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-cobalt inline-block animate-pulse"></span>
      <span class="font-mono text-[9px] uppercase tracking-wider text-stone-grey">
        Opticien Créateur Paris 20
      </span>
    </div>
  </div>

  <!-- Loading Bar Track -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 w-32 h-[1px] bg-stone-grey/20 overflow-hidden">
    <!-- Loading Bar Indicator (Undetermined sliding bar) -->
    <div
      id="preloader-progress"
      class="absolute top-0 bottom-0 w-16 bg-cobalt animate-loading-slide"
    ></div>
  </div>
</div>

<script is:inline>
  (function() {
    const isPlayed = window['__preloaderPlayed'];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!isPlayed && !prefersReducedMotion) {
      const preloader = document.getElementById('preloader');
      if (preloader) {
        preloader.style.display = 'flex';
        document.body.classList.add('preloader-active');
      }
    }
  })();
</script>

<script>
  function runPreloader() {
    const preloader = document.getElementById('preloader');
    const skipBtn = document.getElementById('preloader-skip');

    if (!preloader) return;

    // Check conditions to bypass preloader (window variable or reduced motion)
    const isPlayed = window['__preloaderPlayed'];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const bypass = () => {
      preloader.style.display = 'none';
      document.body.classList.remove('preloader-active');
    };

    if (isPlayed || prefersReducedMotion) {
      bypass();
      return;
    }

    // Lock scrolling on load
    document.body.classList.add('preloader-active');

    const finish = () => {
      preloader.style.opacity = '0';
      window['__preloaderPlayed'] = true;
      setTimeout(() => {
        preloader.style.display = 'none';
        document.body.classList.remove('preloader-active');
      }, 600);
    };

    // Auto-dissolve timer
    const mainTimer = setTimeout(finish, 2100);

    if (skipBtn) {
      skipBtn.addEventListener('click', () => {
        clearTimeout(mainTimer);
        finish();
      });
    }

    return () => {
      clearTimeout(mainTimer);
    };
  }

  // Run immediately on script execution to catch initial load
  let cleanup = runPreloader();

  // Also run on page load for client-side view transition navigations
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = runPreloader();
  });
</script>

<style is:global>
  /* Custom class to lock scrolling */
  body.preloader-active {
    overflow: hidden !important;
    pointer-events: none;
  }
  body.preloader-active #preloader {
    pointer-events: auto;
  }

  /* Tagline (Slogan) fade-in */
  .animate-slogan-in {
    animation: slogan-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
  }
  @keyframes slogan-in {
    0% {
      transform: translateY(20px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 0.6;
    }
  }

  /* Lens circle scale/opacity/blur keyframes matching original Framer Motion curves */
  .animate-lens-in {
    animation: lens-in 1.8s cubic-bezier(0.42, 0, 0.58, 1) forwards;
    opacity: 0;
  }
  @keyframes lens-in {
    0% {
      transform: scale(0.6);
      opacity: 0;
      filter: blur(15px);
    }
    50% {
      transform: scale(1.1);
      opacity: 0.4;
      filter: blur(4px);
    }
    100% {
      transform: scale(1.0);
      opacity: 0.15;
      filter: blur(20px);
    }
  }

  /* Logo container fade-in */
  .animate-logo-in {
    animation: logo-in 1.2s cubic-bezier(0.76, 0, 0.24, 1) forwards;
    opacity: 0;
  }
  @keyframes logo-in {
    0% {
      transform: scale(0.9);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  /* Bottom badge fade-in */
  .animate-badge-in {
    animation: badge-in 0.5s ease-out 0.8s forwards;
    opacity: 0;
  }
  @keyframes badge-in {
    0% {
      transform: translateY(10px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Loading bar sliding indicator track */
  .animate-loading-slide {
    animation: loading-slide 1.8s cubic-bezier(0.42, 0, 0.58, 1) forwards;
    position: absolute;
    top: 0;
    bottom: 0;
  }
  @keyframes loading-slide {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }
</style>
