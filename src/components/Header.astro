---
import Logo from './Logo.astro';
import { settings as mockSettings } from '../data/mockData.js';
import { sanityClient, SETTINGS_QUERY, cleanStega } from '../lib/sanity.js';

let settings = mockSettings;
try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings in Header:", e);
}

const currentPath = Astro.url.pathname;
const cleanPath = currentPath.replace(/\/$/, '');

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/' || currentPath === '/index.html';
  const cleanItemPath = path.replace(/\/$/, '');
  return cleanPath === cleanItemPath || cleanPath.startsWith(cleanItemPath + '/');
};

const navItems = [
  { id: 'home', label: settings.navHomeLabel || 'Accueil Opticien', num: '01', path: '/', img: 'https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=400&q=80' },
  { id: 'collections', label: settings.navCollectionsLabel || 'Lookbook & Lunettes', num: '02', path: '/collections', img: 'https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=400&q=80' },
  { id: 'services', label: settings.navServicesLabel || 'L’Art de l’Optique', num: '03', path: '/services', img: 'https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=400&q=80' },
  { id: 'boutique', label: settings.navBoutiqueLabel || 'L’Atelier Rue d’Avron', num: '04', path: '/boutique', img: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80' },
  { id: 'contact', label: settings.navContactLabel || 'Prendre rendez-vous', num: '05', path: '/contact', img: 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=400&q=80' }
];

const isCollectionsActive = isActive('/collections') || currentPath.includes('/frame/');
const isServicesActive = isActive('/services');
const isBoutiqueActive = isActive('/boutique');
---

<header id="app-main-header" class="fixed top-0 left-0 right-0 z-50 bg-ivory/80 backdrop-blur-md border-b border-stone-grey/10 py-8 px-6 md:px-12 flex items-center justify-between transition-colors duration-300">
  <div class="flex items-center gap-6">
    <a id="header-logo-btn" href="/" data-cursor-label="Accueil" class="flex items-center gap-3 text-left group">
      <Logo size="custom" width={64} showText={true} inverse={false} class="items-start text-left" />
      <div class="hidden xs:block h-6 w-[1px] bg-stone-grey/25 self-center mt-1"></div>
      <span class="hidden xs:block font-mono text-[8.5px] uppercase tracking-[0.25em] text-stone-grey/80 text-left mt-1 self-center max-w-[140px] leading-[1.3] font-medium">
        Opticien Créateur Paris 20
      </span>
    </a>
  </div>

  <nav id="header-desktop-nav" class="hidden lg:flex items-center gap-8 font-mono text-[11px] uppercase tracking-widest text-optical-black">
    <a href="/collections" class={`hover:text-cobalt transition-colors duration-300 relative py-1 ${isCollectionsActive ? 'text-cobalt font-medium' : ''}`}>
      {settings.navCollectionsLabel || "Collection"}
      {isCollectionsActive && <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-cobalt"></span>}
    </a>
    <a href="/services" class={`hover:text-cobalt transition-colors duration-300 relative py-1 ${isServicesActive ? 'text-cobalt font-medium' : ''}`}>
      {settings.navServicesLabel || "Savoir-Faire"}
      {isServicesActive && <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-cobalt"></span>}
    </a>
    <a href="/boutique" class={`hover:text-cobalt transition-colors duration-300 relative py-1 ${isBoutiqueActive ? 'text-cobalt font-medium' : ''}`}>
      {settings.navBoutiqueLabel || "La Boutique"}
      {isBoutiqueActive && <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-cobalt"></span>}
    </a>
    <a href="/contact" class="ml-4 bg-cobalt hover:bg-optical-black text-ivory px-5 py-2.5 transition-colors duration-300 text-[10px] tracking-widest font-semibold">
      {settings.navButtonText || "Rendez-vous"}
    </a>
  </nav>

  <div class="flex items-center gap-4">
    <button id="header-hamburger-toggle" data-cursor-label="MENU" class="flex items-center gap-3 bg-optical-black text-ivory hover:bg-cobalt px-4 py-2.5 transition-all duration-300 relative z-[60]" aria-label="Toggle navigation menu">
      <span id="hamburger-text" class="font-mono text-[10px] uppercase tracking-widest hidden md:inline">Menu</span>
      <svg id="hamburger-icon-menu" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg id="hamburger-icon-close" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
    </button>
  </div>
</header>

<div id="fullscreen-menu-overlay" class="fixed inset-0 z-40 bg-optical-black text-ivory flex flex-col pt-28 pb-10 px-6 md:px-12 lg:px-24 justify-between overflow-y-auto hidden opacity-0 transition-opacity duration-300">
  {/* Background line grids */}
  <div class="absolute inset-x-0 top-0 bottom-0 pointer-events-none opacity-5 grid grid-cols-4 divide-x divide-ivory">
    <div></div>
    <div></div>
    <div></div>
    <div></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center justify-center my-auto relative z-10">
    <div class="col-span-1 lg:col-span-7 flex flex-col gap-6 md:gap-10">
      <span class="font-mono text-[9px] uppercase tracking-[0.25em] text-stone-grey block border-b border-stone-grey/25 pb-3">Navigation</span>
      <nav id="overlay-menu-nav" class="flex flex-col gap-4 md:gap-6">
        {navItems.map((item) => {
          const active = currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path));
          return (
            <div class="group overlay-link-wrap animate-fade-in" data-img={item.img}>
              <a href={item.path} class="text-left flex items-baseline gap-4 md:gap-8 group">
                <span class="font-mono text-xs md:text-sm text-cobalt opacity-70 group-hover:opacity-100 transition-opacity">{item.num}</span>
                <span style="font-family: var(--font-display);" class={`text-3xl md:text-5xl lg:text-6xl font-light tracking-tight group-hover:translate-x-3 transition-transform duration-300 ${active ? 'font-medium text-cobalt' : 'text-ivory'}`}>
                  {item.label}
                </span>
              </a>
            </div>
          );
        })}
      </nav>
    </div>

    <div class="col-span-1 lg:col-span-5 hidden lg:flex flex-col gap-8 relative items-center justify-center">
      <div class="w-full max-w-sm aspect-[4/5] bg-stone-grey/10 relative overflow-hidden flex items-center justify-center">
        <div id="overlay-preview-container" class="absolute inset-0">
          <img id="overlay-preview-img" src="" alt="Aperçu visuel AlexSEE" class="w-full h-full object-cover opacity-80" referrerpolicy="no-referrer" />
        </div>
        <div id="overlay-placeholder" class="p-8 text-center flex flex-col items-center justify-center h-full relative transition-opacity duration-300">
          <div class="w-32 h-32 rounded-full border border-stone-grey/25 mb-6 flex items-center justify-center animate-lens-pulse">
            <span class="font-mono text-[9px] uppercase tracking-widest text-stone-grey">Lentille</span>
          </div>
          <p class="font-mono text-[10px] text-stone-grey tracking-widest uppercase">AlexSEE — Paris 20e</p>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-stone-grey/25 pt-6 grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-[10px] tracking-wider text-stone-grey uppercase relative z-10">
    <div>
      <span class="text-ivory block mb-2 font-semibold">Atelier Paris 20</span>
      <span class="block normal-case flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        {settings.address}, Paris 20e
      </span>
      <span class="block text-[9px] text-stone-grey/80 lowercase mt-1">{settings.metro}</span>
    </div>
    <div>
      <span class="text-ivory block mb-2 font-semibold">Heures d’ouverture</span>
      <span class="block flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Lun: 14h – 19h30
      </span>
      <span class="block">Mar – Sam: 10h – 19h30</span>
    </div>
    <div class="flex flex-col gap-2 justify-between">
      <div>
        <span class="text-ivory block mb-1 font-semibold">Aide & Contact</span>
        <a href={`tel:${cleanStega(settings.phone)}`} class="hover:text-cobalt transition-colors inline-flex items-center gap-1.5 font-bold text-ivory">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt animate-bounce"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.58 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10a16 16 0 0 0 6 6l.72-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {settings.phone}
        </a>
      </div>
      <div class="flex gap-4 items-center">
        <a href={cleanStega(settings.instagram)} target="_blank" rel="noopener noreferrer" class="hover:text-cobalt transition-colors inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          Instagram
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function setupHeader() {
    const hamburgerBtn = document.getElementById('header-hamburger-toggle');
    const overlay = document.getElementById('fullscreen-menu-overlay');
    const textSpan = document.getElementById('hamburger-text');
    const iconMenu = document.getElementById('hamburger-icon-menu');
    const iconClose = document.getElementById('hamburger-icon-close');

    if (!hamburgerBtn || !overlay) return;

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      if (isOpen) {
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => {
          overlay.classList.remove('opacity-0');
        }, 10);
        if (textSpan) textSpan.textContent = 'Fermer';
        hamburgerBtn.setAttribute('data-cursor-label', 'FERMER');
        iconMenu?.classList.replace('block', 'hidden');
        iconClose?.classList.replace('hidden', 'block');
      } else {
        overlay.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => {
          overlay.classList.add('hidden');
        }, 300);
        if (textSpan) textSpan.textContent = 'Menu';
        hamburgerBtn.setAttribute('data-cursor-label', 'MENU');
        iconMenu?.classList.replace('hidden', 'block');
        iconClose?.classList.replace('block', 'hidden');
      }
    };

    hamburgerBtn.addEventListener('click', toggleMenu);

    // Hover image logic
    const linkWraps = document.querySelectorAll('.overlay-link-wrap');
    const previewContainer = document.getElementById('overlay-preview-container');
    const previewImg = document.getElementById('overlay-preview-img') as HTMLImageElement | null;
    const placeholder = document.getElementById('overlay-placeholder');

    let placeholderTimeout = null;
    let transitionTimeout = null;

    linkWraps.forEach(wrap => {
      wrap.addEventListener('mouseenter', () => {
        if (placeholderTimeout) {
          clearTimeout(placeholderTimeout);
          placeholderTimeout = null;
        }
        if (transitionTimeout) {
          clearTimeout(transitionTimeout);
          transitionTimeout = null;
        }

        const imgUrl = wrap.getAttribute('data-img');
        if (imgUrl && previewImg && previewContainer && placeholder) {
          const isCurrentlyActive = previewContainer.classList.contains('active');
          const currentSrc = previewImg.src;

          if (isCurrentlyActive && currentSrc && !currentSrc.includes(imgUrl)) {
            // Fade out the old image first (exit transition)
            previewContainer.classList.remove('active');
            previewContainer.classList.add('exiting');
            
            transitionTimeout = setTimeout(() => {
              previewImg.src = imgUrl;
              previewContainer.classList.remove('exiting');
              previewContainer.classList.add('active');
              placeholder.classList.add('opacity-0');
              transitionTimeout = null;
            }, 250); // wait for exit transition (250ms)
          } else {
            // First time fade in from placeholder
            previewImg.src = imgUrl;
            previewContainer.classList.remove('exiting');
            previewContainer.classList.add('active');
            placeholder.classList.add('opacity-0');
          }
        }
      });

      wrap.addEventListener('mouseleave', () => {
        placeholderTimeout = setTimeout(() => {
          if (previewContainer && placeholder) {
            previewContainer.classList.remove('active', 'exiting');
            placeholder.classList.remove('opacity-0');
            
            setTimeout(() => {
              if (!previewContainer.classList.contains('active') && previewImg) {
                previewImg.src = '';
              }
            }, 300);
          }
          placeholderTimeout = null;
        }, 50); // small delay to allow override by next enter
      });

      // Close menu when a link is clicked
      wrap.querySelector('a')?.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    return () => {
      hamburgerBtn.removeEventListener('click', toggleMenu);
      document.body.style.overflow = '';
      if (placeholderTimeout) clearTimeout(placeholderTimeout);
      if (transitionTimeout) clearTimeout(transitionTimeout);
    };
  }

  let cleanup;
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = setupHeader();
  });
</script>

<style>
  #overlay-preview-container {
    transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                filter 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    opacity: 0;
    transform: scale(1.15);
    filter: blur(10px);
    pointer-events: none;
  }
  #overlay-preview-container.active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0px);
  }
  #overlay-preview-container.exiting {
    opacity: 0;
    transform: scale(0.95);
    filter: blur(5px);
  }
</style>
