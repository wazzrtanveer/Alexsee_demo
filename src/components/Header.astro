---
import Logo from './Logo.astro';
import { settings as mockSettings } from '../data/mockData.js';
import { sanityClient, SETTINGS_QUERY, cleanStega, dataAttribute, urlFor } from '../lib/sanity.js';

let settings = mockSettings;
try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings in Header:", e);
}

const currentPath = Astro.url.pathname;
const cleanPath = currentPath.replace(/\/$/, '');

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/' || currentPath === '/index.html';
  const cleanItemPath = path.replace(/\/$/, '');
  return cleanPath === cleanItemPath || cleanPath.startsWith(cleanItemPath + '/');
};

const desktopLinks = [
  { field: 'navCollectionsLabel', label: settings.navCollectionsLabel || 'Collection', path: '/collections' },
  { field: 'navServicesLabel', label: settings.navServicesLabel || 'Savoir-Faire', path: '/services' },
  { field: 'navBoutiqueLabel', label: settings.navBoutiqueLabel || 'La Boutique', path: '/boutique' }
];

const overlayLinks = settings.headerLinks && settings.headerLinks.length > 0
  ? settings.headerLinks.map((item, index) => ({
      _key: item._key,
      label: item.label,
      path: item.path,
      num: item.num || String(index + 1).padStart(2, '0'),
      img: item.image ? urlFor(item.image) : (
        item.path === '/' ? 'https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=400&q=80' :
        item.path.includes('collections') ? 'https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=400&q=80' :
        item.path.includes('services') ? 'https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=400&q=80' :
        item.path.includes('boutique') ? 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80' :
        'https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=400&q=80'
      )
    }))
  : [
      { label: settings.navHomeLabel || 'Accueil Opticien', path: '/', num: '01', img: 'https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=400&q=80' },
      { label: settings.navCollectionsLabel || 'Lookbook & Lunettes', path: '/collections', num: '02', img: 'https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=400&q=80' },
      { label: settings.navServicesLabel || 'L’Art de l’Optique', path: '/services', num: '03', img: 'https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=400&q=80' },
      { label: settings.navBoutiqueLabel || 'L’Atelier Rue d’Avron', path: '/boutique', num: '04', img: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80' },
      { label: settings.navContactLabel || 'Prendre rendez-vous', path: '/contact', num: '05', img: 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=400&q=80' }
    ];

const socialLinks = settings.socialLinks && settings.socialLinks.length > 0
  ? settings.socialLinks
  : settings.instagram
    ? [{ _key: 'default-instagram', platform: 'instagram', url: settings.instagram }]
    : [{ _key: 'default-instagram', platform: 'instagram', url: 'https://www.instagram.com/alexsee.avron/' }];
---

<header id="app-main-header" transition:persist class="fixed top-0 left-0 right-0 z-50 bg-ivory/80 backdrop-blur-md border-b border-stone-grey/10 py-5 px-6 md:px-12 flex items-center justify-between transition-colors duration-300">
  <div class="flex items-center gap-6">
    <a id="header-logo-btn" href="/" data-cursor-label="Accueil" class="flex items-center gap-3 text-left group ml-2 md:ml-4">
      <Logo size="target" showText={true} inverse={false} class="items-start text-left" />
      <div class="hidden xs:block h-6 w-[1px] bg-stone-grey/25 self-center mt-1"></div>
      <span class="hidden xs:block font-mono text-[8.5px] uppercase tracking-[0.25em] text-stone-grey/80 text-left mt-1 self-center max-w-[140px] leading-[1.3] font-medium">
        Opticien Créateur Paris 20
      </span>
    </a>
  </div>

  <nav id="header-desktop-nav" class="hidden lg:flex items-center gap-8 font-mono text-[11px] tracking-widest text-optical-black">
    {desktopLinks.map((item) => {
      const active = isActive(item.path || "#") || (item.path && cleanStega(item.path) === '/collections' && currentPath.includes('/frame/'));
      return (
        <a 
          href={item.path || "#"} 
          data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: item.field }) : undefined}
          class={`hover:text-cobalt transition-colors duration-300 relative py-1 ${active ? 'text-cobalt font-medium' : ''}`}
        >
          {item.label || ""}
          {active && <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-cobalt"></span>}
        </a>
      );
    })}
    <a href="/contact" class="ml-4 bg-cobalt hover:bg-optical-black text-ivory px-5 py-2.5 transition-colors duration-300 text-[10px] tracking-widest font-semibold" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'navButtonText' }) : undefined}>
      {settings.navButtonText || "Rendez-vous"}
    </a>
  </nav>

  <div class="flex items-center gap-4">
    <button id="header-hamburger-toggle" data-cursor-label="MENU" class="flex items-center gap-3 bg-optical-black text-ivory hover:bg-cobalt px-4 py-2.5 transition-all duration-300 relative z-[60]" aria-label="Toggle navigation menu">
      <span id="hamburger-text" class="font-mono text-[10px] uppercase tracking-widest hidden md:inline">Menu</span>
      <svg id="hamburger-icon-menu" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg id="hamburger-icon-close" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
    </button>
  </div>
</header>

<div id="fullscreen-menu-overlay" class="fixed inset-0 z-40 bg-optical-black text-ivory flex flex-col pt-28 pb-10 px-6 md:px-12 lg:px-24 justify-between overflow-y-auto hidden opacity-0 transition-opacity duration-300">
  {/* Background line grids */}
  <div class="absolute inset-x-0 top-0 bottom-0 pointer-events-none opacity-5 grid grid-cols-4 divide-x divide-ivory">
    <div></div>
    <div></div>
    <div></div>
    <div></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center justify-center my-auto relative z-10">
    <div class="col-span-1 lg:col-span-7 flex flex-col gap-6 md:gap-10">
      <span class="font-mono text-[9px] uppercase tracking-[0.25em] text-stone-grey block border-b border-stone-grey/25 pb-3">Navigation</span>
      <nav id="overlay-menu-nav" class="flex flex-col gap-4 md:gap-6" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'headerLinks' }) : undefined}>
        {overlayLinks.map((item, index) => {
          const active = currentPath === (item.path || "#") || (item.path && item.path !== '/' && currentPath.startsWith(item.path));
          return (
            <div 
              class="group overlay-link-wrap animate-fade-in" 
              data-img={item.img}
              data-index={index}
              data-sanity={settings._id ? (item._key ? dataAttribute({ id: settings._id, type: settings._type, path: `headerLinks[_key == "${item._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'headerLinks' })) : undefined}
            >
              <a href={item.path || "#"} class="text-left flex items-baseline gap-4 md:gap-8 group">
                <span class="font-mono text-xs md:text-sm text-cobalt opacity-70 group-hover:opacity-100 transition-opacity">{item.num}</span>
                <span style="font-family: var(--font-display);" class={`text-3xl md:text-5xl lg:text-6xl font-light tracking-tight group-hover:translate-x-3 transition-transform duration-300 ${active ? 'font-medium text-cobalt' : 'text-ivory'}`}>
                  {item.label || ""}
                </span>
              </a>
            </div>
          );
        })}
      </nav>
    </div>

    <div class="col-span-1 lg:col-span-5 hidden lg:flex flex-col gap-8 relative items-center justify-center">
      <div class="w-full max-w-sm aspect-[4/5] bg-stone-grey/10 relative overflow-hidden flex items-center justify-center">
        <div id="overlay-preview-container" class="absolute inset-0">
          {overlayLinks.map((item, idx) => (
            <img 
              data-img-index={idx}
              src={item.img} 
              alt={`Aperçu ${item.label}`} 
              class="overlay-preview-img-layer absolute inset-0 w-full h-full object-cover opacity-0 pointer-events-none" 
              data-sanity={settings._id && item._key ? dataAttribute({ id: settings._id, type: settings._type, path: `headerLinks[_key == "${item._key}"]` }) : undefined}
              referrerpolicy="no-referrer" 
            />
          ))}
        </div>
        <div id="overlay-placeholder" class="p-8 text-center flex flex-col items-center justify-center h-full relative transition-opacity duration-300">
          <div class="w-32 h-32 rounded-full border border-stone-grey/25 mb-6 flex items-center justify-center animate-lens-pulse">
            <span class="font-mono text-[9px] uppercase tracking-widest text-stone-grey">Lentille</span>
          </div>
          <p class="font-mono text-[10px] text-stone-grey tracking-widest uppercase">AlexSEE — Paris 20e</p>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-stone-grey/25 pt-6 grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-[10px] tracking-wider text-stone-grey uppercase relative z-10">
    <div>
      <span class="text-ivory block mb-2 font-semibold" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'navBoutiqueTitle' }) : undefined}>
        {settings.navBoutiqueTitle || "Atelier Paris 20"}
      </span>
      <span class="block normal-case flex items-center gap-1.5" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'address' }) : undefined}>
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        {settings.address}, Paris 20e
      </span>
      <span class="block text-[9px] text-stone-grey/80 lowercase mt-1" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'metro' }) : undefined}>
        {settings.metro}
      </span>
    </div>
    <div>
      <span class="text-ivory block mb-2 font-semibold" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'navHoursTitle' }) : undefined}>
        {settings.navHoursTitle || "Heures d’ouverture"}
      </span>
      {settings.hours && settings.hours.length > 0 ? (
        settings.hours.map((item, idx) => (
          <span class="block flex items-center gap-1.5" data-sanity={settings._id ? (item._key ? dataAttribute({ id: settings._id, type: settings._type, path: `hours[_key == "${item._key}"]` }) : dataAttribute({ id: settings._id, type: settings._type, path: 'hours' })) : undefined}>
            {idx === 0 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            )}
            {idx > 0 && <span class="w-[11px] h-[11px] inline-block shrink-0" />}
            {item.days}: {item.hours}
          </span>
        ))
      ) : (
        <>
          <span class="block flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Lun: 14h – 19h30
          </span>
          <span class="block"><span class="w-[11px] h-[11px] inline-block shrink-0" />Mar – Sam: 10h – 19h30</span>
        </>
      )}
    </div>
    <div class="flex flex-col gap-2 justify-between">
      <div>
        <span class="text-ivory block mb-1 font-semibold" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'navContactTitle' }) : undefined}>
          {settings.navContactTitle || "Aide & Contact"}
        </span>
        <a 
          href={`tel:${cleanStega(settings.phone)}`} 
          data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'phone' }) : undefined}
          class="hover:text-cobalt transition-colors inline-flex items-center gap-1.5 font-bold text-ivory"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt animate-bounce"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.58 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10a16 16 0 0 0 6 6l.72-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {settings.phone}
        </a>
      </div>
      <div class="flex gap-4 items-center" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'socialLinks' }) : undefined}>
        {socialLinks.map((social) => {
          const cleanUrl = cleanStega(social.url) || "#";
          const platform = cleanStega(social.platform) || "website";
          const displayPlatform = platform === 'twitter' ? 'Twitter / X' : (platform === 'website' ? 'Site Web' : platform.charAt(0).toUpperCase() + platform.slice(1));
          return (
            <a 
              href={cleanUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              data-sanity={settings._id ? (social._key === 'default-instagram' ? dataAttribute({ id: settings._id, type: settings._type, path: 'instagram' }) : dataAttribute({ id: settings._id, type: settings._type, path: `socialLinks[_key == "${social._key}"]` })) : undefined}
              class="hover:text-cobalt transition-colors inline-flex items-center gap-1.5"
            >
              {platform === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              )}
              {platform === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              )}
              {platform === 'twitter' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
              )}
              {platform === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              )}
              {platform === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/><path d="m10 15 5-3-5-3z"/></svg>
              )}
              {platform === 'tiktok' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              )}
              {platform === 'website' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              )}
              {displayPlatform}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</div>

<script>
  function setupHeader() {
    const header = document.getElementById('app-main-header');
    const hamburgerBtn = document.getElementById('header-hamburger-toggle');
    const overlay = document.getElementById('fullscreen-menu-overlay');
    const textSpan = document.getElementById('hamburger-text');
    const iconMenu = document.getElementById('hamburger-icon-menu');
    const iconClose = document.getElementById('hamburger-icon-close');

    if (!hamburgerBtn || !overlay) return;

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      const logoBtn = document.getElementById('header-logo-btn');
      const desktopNav = document.getElementById('header-desktop-nav');
      if (isOpen) {
        header?.classList.add('menu-open');
        header?.classList.remove('bg-ivory/80', 'backdrop-blur-md', 'border-stone-grey/10');
        header?.classList.add('bg-transparent', 'backdrop-blur-none', 'border-transparent');
        if (logoBtn) {
          logoBtn.style.opacity = '0';
          logoBtn.style.pointerEvents = 'none';
        }
        if (desktopNav) {
          desktopNav.style.opacity = '0';
          desktopNav.style.pointerEvents = 'none';
        }
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => {
          overlay.classList.remove('opacity-0');
        }, 10);
        if (textSpan) textSpan.textContent = 'Fermer';
        hamburgerBtn.setAttribute('data-cursor-label', 'FERMER');
        iconMenu?.classList.replace('block', 'hidden');
        iconClose?.classList.replace('hidden', 'block');
      } else {
        header?.classList.remove('menu-open');
        header?.classList.remove('bg-transparent', 'backdrop-blur-none', 'border-transparent');
        header?.classList.add('bg-ivory/80', 'backdrop-blur-md', 'border-stone-grey/10');
        if (logoBtn) {
          logoBtn.style.opacity = '';
          logoBtn.style.pointerEvents = '';
        }
        if (desktopNav) {
          desktopNav.style.opacity = '';
          desktopNav.style.pointerEvents = '';
        }
        overlay.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => {
          overlay.classList.add('hidden');
        }, 300);
        if (textSpan) textSpan.textContent = 'Menu';
        hamburgerBtn.setAttribute('data-cursor-label', 'MENU');
        iconMenu?.classList.replace('hidden', 'block');
        iconClose?.classList.replace('block', 'hidden');
      }
    };

    hamburgerBtn.addEventListener('click', toggleMenu);

    // Hover image logic
    const linkWraps = document.querySelectorAll('.overlay-link-wrap');
    const previewContainer = document.getElementById('overlay-preview-container');
    const previewImgLayers = document.querySelectorAll('.overlay-preview-img-layer');
    const placeholder = document.getElementById('overlay-placeholder');

    let placeholderTimeout = null;

    linkWraps.forEach(wrap => {
      wrap.addEventListener('mouseenter', () => {
        if (placeholderTimeout) {
          clearTimeout(placeholderTimeout);
          placeholderTimeout = null;
        }

        const index = wrap.getAttribute('data-index');
        if (previewContainer && placeholder) {
          previewContainer.classList.add('active');
          placeholder.classList.add('opacity-0');

          previewImgLayers.forEach(layer => {
            const isTarget = layer.getAttribute('data-img-index') === index;
            if (isTarget) {
              layer.classList.remove('opacity-0', 'exiting', 'pointer-events-none');
              layer.classList.add('active', 'pointer-events-auto');
            } else {
              if (layer.classList.contains('active')) {
                layer.classList.remove('active', 'pointer-events-auto');
                layer.classList.add('exiting', 'pointer-events-none');
                
                setTimeout(() => {
                  if (layer.classList.contains('exiting')) {
                    layer.classList.remove('exiting');
                    layer.classList.add('opacity-0');
                  }
                }, 400); // match transition duration (0.4s)
              } else {
                layer.classList.add('opacity-0', 'pointer-events-none');
                layer.classList.remove('active', 'exiting', 'pointer-events-auto');
              }
            }
          });
        }
      });

      wrap.addEventListener('mouseleave', () => {
        placeholderTimeout = setTimeout(() => {
          if (previewContainer && placeholder) {
            previewContainer.classList.remove('active');
            placeholder.classList.remove('opacity-0');
            
            previewImgLayers.forEach(layer => {
              if (layer.classList.contains('active')) {
                layer.classList.remove('active', 'pointer-events-auto');
                layer.classList.add('exiting', 'pointer-events-none');
                
                setTimeout(() => {
                  if (layer.classList.contains('exiting')) {
                    layer.classList.remove('exiting');
                    layer.classList.add('opacity-0');
                  }
                }, 400);
              } else {
                layer.classList.add('opacity-0', 'pointer-events-none');
                layer.classList.remove('active', 'exiting', 'pointer-events-auto');
              }
            });
          }
          placeholderTimeout = null;
        }, 50); // small delay to allow override by next enter
      });

      // Close menu when a link is clicked
      wrap.querySelector('a')?.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    return () => {
      hamburgerBtn.removeEventListener('click', toggleMenu);
      document.body.style.overflow = '';
      if (placeholderTimeout) clearTimeout(placeholderTimeout);
    };
  }

  let cleanup;
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = setupHeader();
  });
</script>

