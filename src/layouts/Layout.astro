---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Header from '../components/Header.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Preloader from '../components/Preloader.astro';
import { VisualEditing } from '@sanity/astro/visual-editing';
import '../styles/global.css';

const { 
  title = "AlexSEE — Opticien Créateur Paris 20e", 
  description = "Boutique d'optique indépendante à Paris 20e (Charonne - Nation). Découvrez notre vestiaire de lunettes de créateurs et profitez d'un accompagnement personnalisé d'une heure."
} = Astro.props;

const isVisualEditingEnabled = import.meta.env.DEV;
---

<!DOCTYPE html>
<html lang="fr" class="bg-ivory text-optical-black selection:bg-cobalt selection:text-ivory">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Preconnect to fonts and images -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    {/* Enable Astro's view transitions */}
    <ClientRouter />
  </head>
  <body class="overflow-x-hidden antialiased min-h-screen bg-ivory text-optical-black relative font-sans noise-overlay selection:bg-cobalt selection:text-ivory">
    <div id="root" class="min-h-screen">
      {/* Global Preloader */}
      <Preloader />

      {/* Global Custom Lens Cursor */}
      <CustomCursor />

      {/* Global Sticky Navigation Header */}
      <Header />

      {/* Main Page Slot */}
      <div 
        id="main-content" 
        class="w-full"
      >
        <slot />
      </div>
    </div>

    <VisualEditing enabled={isVisualEditingEnabled} zIndex={9999} />

    <script>
      // Block native link navigation and button clicks only when inside the Sanity iframe AND edit mode is active.
      if (window.self !== window.top) {
        window.addEventListener('click', (event) => {
          // Allow modifier clicks (e.g. Alt + Click) for native navigation
          if (event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) {
            return;
          }
          
          // Check if overlays are currently active on the page (indicating Edit Mode is ON)
          const hasOverlays = !!document.querySelector('[data-sanity-overlay-element]');
          if (hasOverlays) {
            const target = event.target;
            if (target instanceof Element) {
              // Only block clicks if they did not hit a visual editing overlay element
              const isOverlayClick = !!target.closest('[data-sanity-overlay-element]') || target.hasAttribute('data-sanity-overlay-element');
              if (!isOverlayClick) {
                const interactiveElement = target.closest('a, button');
                if (interactiveElement) {
                  // Block the navigation / action trigger
                  event.preventDefault();
                  event.stopPropagation();
                }
              }
            }
          }
        }, true); // Capture phase to intercept before React/native handlers run
      }
    </script>
  </body>
</html>
