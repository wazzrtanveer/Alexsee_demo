---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Header from '../components/Header.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Preloader from '../components/Preloader.astro';
import '../styles/global.css';

const { 
  title = "AlexSEE — Opticien Créateur Paris 20e", 
  description = "Boutique d'optique indépendante à Paris 20e (Charonne - Nation). Découvrez notre vestiaire de lunettes de créateurs et profitez d'un accompagnement personnalisé d'une heure."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" class="bg-ivory text-optical-black selection:bg-cobalt selection:text-ivory">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Preconnect to fonts and images -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    {/* Enable Astro's view transitions */}
    <ClientRouter />
  </head>
  <body class="overflow-x-hidden antialiased min-h-screen bg-ivory text-optical-black relative font-sans noise-overlay selection:bg-cobalt selection:text-ivory">
    <div id="root" class="min-h-screen">
      {/* Global Preloader */}
      <Preloader />

      {/* Global Custom Lens Cursor */}
      <CustomCursor />

      {/* Global Sticky Navigation Header */}
      <Header />

      {/* Main Page Slot */}
      <div 
        id="main-content" 
        class="w-full"
      >
        <slot />
      </div>
    </div>

    <script>
      import { enableVisualEditing } from '@sanity/visual-editing';

      let disableVisualEditing = null;

      function initVisualEditing() {
        if (disableVisualEditing) {
          disableVisualEditing();
          disableVisualEditing = null;
        }

        if (window.self !== window.top) {
          disableVisualEditing = enableVisualEditing({
            zIndex: 9999,
            history: {
              subscribe: (navigate) => {
                // Listens to navigation updates from Sanity Studio
                const handlePopState = () => {
                  navigate({
                    pathname: window.location.pathname,
                    search: window.location.search,
                  });
                };
                window.addEventListener('popstate', handlePopState);
                return () => window.removeEventListener('popstate', handlePopState);
              },
              update: (update) => {
                // Updates the browser history when a user navigates inside the iframe
                if (update.type === 'push') {
                  window.history.pushState(null, '', update.url);
                } else if (update.type === 'replace') {
                  window.history.replaceState(null, '', update.url);
                }
              },
            },
          });
        }
      }

      // Initialize on initial page load
      initVisualEditing();

      // Listen for Astro page-load event to re-initialize visual editing on view transitions
      document.addEventListener('astro:page-load', initVisualEditing);

      // Block native link navigation, button clicks, and form submissions inside the Sanity iframe when visual edit mode is active.
      if (window.self !== window.top) {
        // Track the current edit mode state. Persist via sessionStorage so it survives page reloads inside the iframe.
        let isEditModeActive = sessionStorage.getItem('sanity-edit-mode') === 'true';

        // Listen for messaging events from Sanity Studio/Presentation Tool
        window.addEventListener('message', (event) => {
          const data = event.data;
          if (data && typeof data === 'object') {
            let enabled = null;
            
            // Handle different variations of Comlink and Channels messages
            if (data.type === 'post' && data.data && data.data.type === 'visual-editing/toggle') {
              enabled = data.data.data?.enabled;
            } else if (data.type === 'visual-editing/toggle') {
              enabled = data.data?.enabled;
            } else if (data.type === 'presentation/toggle-overlay') {
              enabled = data.data?.enabled;
            } else if (data.type === 'overlay/toggle') {
              enabled = data.data?.enabled;
            }
            
            if (typeof enabled === 'boolean') {
              isEditModeActive = enabled;
              sessionStorage.setItem('sanity-edit-mode', enabled.toString());
              console.log('[EditMode Blocker] Edit mode state updated:', enabled);
            }
          }
        });

        // Heuristic function to determine if edit mode is active
        function isEditMode() {
          return isEditModeActive || 
                 sessionStorage.getItem('sanity-edit-mode') === 'true' || 
                 !!document.querySelector('[data-sanity-overlay-element]');
        }

        // Intercept clicks in the capture phase to block them before any framework routing or page logic runs
        window.addEventListener('click', (event) => {
          // Allow modifier clicks (e.g., Ctrl/Cmd + Click) for developer backdoors if needed
          if (event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) {
            return;
          }

          if (isEditMode()) {
            const target = event.target;
            if (target instanceof Element) {
              // Check if the click target or any of its ancestors is a Sanity overlay element.
              // If it is an overlay click, we let it propagate so that Sanity Studio can select the field.
              const isOverlayClick = !!target.closest('[data-sanity-overlay-element]') || target.hasAttribute('data-sanity-overlay-element');
              
              if (!isOverlayClick) {
                // Determine if this click targets an interactive element (link, button, custom clickable, form input)
                const interactiveElement = target.closest('a, button, [role="button"], input, select, textarea, [onclick]');
                const hasClickableCursor = target.classList.contains('cursor-pointer') || target.closest('.cursor-pointer');

                if (interactiveElement || hasClickableCursor) {
                  // Completely block the event
                  event.preventDefault();
                  event.stopPropagation();
                  console.log('[EditMode Blocker] Intercepted and blocked action in Edit Mode:', interactiveElement || target);
                }
              }
            }
          }
        }, true);

        // Also prevent form submissions when edit mode is active
        window.addEventListener('submit', (event) => {
          if (isEditMode()) {
            event.preventDefault();
            event.stopPropagation();
            console.log('[EditMode Blocker] Intercepted and blocked form submission in Edit Mode');
          }
        }, true);
      }
    </script>
  </body>
</html>
