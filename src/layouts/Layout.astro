---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Preloader from '../components/Preloader.astro';
import { settings as mockSettings } from '../data/mockData.js';
import { sanityClient, SETTINGS_QUERY, urlFor } from '../lib/sanity.js';
import '../styles/global.css';

let settings = mockSettings;
try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings in Layout.astro:", e);
}

const faviconUrl = settings.favicon ? urlFor(settings.favicon) : '/favicon.svg';

const { 
  seoTitle,
  seoDescription,
  title = "AlexSEE — Opticien Créateur Paris 20e", 
  description = "Boutique d'optique indépendante à Paris 20e (Charonne - Nation). Découvrez notre vestiaire de lunettes de créateurs et profitez d'un accompagnement personnalisé d'une heure."
} = Astro.props;

const finalTitle = seoTitle || title || "AlexSEE — Opticien Créateur Paris 20e";
const finalDescription = seoDescription || description || "Boutique d'optique indépendante à Paris 20e (Charonne - Nation). Découvrez notre vestiaire de lunettes de créateurs et profitez d'un accompagnement personnalisé d'une heure.";
---

<!DOCTYPE html>
<html lang="fr" class="bg-ivory text-optical-black selection:bg-cobalt selection:text-ivory">
  <head>
    <script is:inline>
      if (window.self !== window.top) {
        // 1. Inside Sanity Studio Presentation Iframe: Disable Google Translate to prevent preview layout shifts
        document.documentElement.classList.add('notranslate');
        document.documentElement.setAttribute('translate', 'no');
        document.documentElement.classList.add('sanity-preview-mode');
      } else {
        // 2. On the Public Live Site: Strip invisible visual editing metadata (stega) from text nodes.
        // This ensures browser translators (like Google Translate) work flawlessly without layout distortion.
        const cleanStegaFromDOM = (node) => {
          if (node.nodeType === 3) {
            const val = node.nodeValue;
            if (val) {
              const cleaned = val.replace(/[\u200B-\u200D\uFEFF]/g, '');
              if (cleaned !== val) {
                node.nodeValue = cleaned;
              }
            }
          } else if (node.nodeName !== 'SCRIPT' && node.nodeName !== 'STYLE') {
            for (let i = 0; i < node.childNodes.length; i++) {
              cleanStegaFromDOM(node.childNodes[i]);
            }
          }
        };

        const runClean = () => {
          if (document.body) cleanStegaFromDOM(document.body);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', runClean);
        } else {
          runClean();
        }
        document.addEventListener('astro:page-load', runClean);
      }
    </script>
    <meta charset="utf-8" />
    <link rel="icon" href={faviconUrl} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{finalTitle}</title>
    <meta name="title" content={finalTitle} />
    <meta name="description" content={finalDescription} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={finalTitle} />
    <meta property="twitter:description" content={finalDescription} />
    <meta property="twitter:image" content="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1200&q=80" />

    <!-- Preconnect to fonts and images -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    {/* Enable Astro's view transitions */}
    <ClientRouter />
  </head>
  <body class="overflow-x-hidden antialiased min-h-screen bg-ivory text-optical-black relative font-sans noise-overlay selection:bg-cobalt selection:text-ivory">
    <div id="root" class="min-h-screen">
      {/* Global Preloader */}
      <Preloader />

      {/* Global Custom Lens Cursor */}
      <CustomCursor />

      {/* Global Sticky Navigation Header */}
      <Header />

      {/* Main Page Slot */}
      <div 
        id="main-content" 
        class="w-full"
      >
        <slot />
      </div>

      {/* Global Footer */}
      <Footer />
    </div>

    <script>
      import { enableVisualEditing } from '@sanity/visual-editing';

      let disableVisualEditing = null;

      function initVisualEditing() {
        if (disableVisualEditing) {
          disableVisualEditing();
          disableVisualEditing = null;
        }

        if (window.self !== window.top) {
          disableVisualEditing = enableVisualEditing({
            zIndex: 9999,
            history: {
              subscribe: (navigate) => {
                // Listens to navigation updates from Sanity Studio
                const handlePopState = () => {
                  const currentUrl = window.location.pathname + window.location.search + window.location.hash;
                  navigate({
                    type: 'push',
                    url: currentUrl,
                    pathname: window.location.pathname,
                    search: window.location.search,
                  });
                };
                window.addEventListener('popstate', handlePopState);
                
                // Immediately synchronize navigation state on mount
                handlePopState();
                
                return () => window.removeEventListener('popstate', handlePopState);
              },
              update: (update) => {
                // Updates the browser history and performs client-side programmatic navigation in Astro View Transitions
                if (update.type === 'push' || update.type === 'replace') {
                  import('astro:transitions/client').then(({ navigate }) => {
                    navigate(update.url);
                  });
                }
              },
            },
          });
        }
      }

      // Initialize on initial page load
      initVisualEditing();

      // Listen for Astro page-load event to re-initialize visual editing on view transitions
      document.addEventListener('astro:page-load', initVisualEditing);
    </script>
  </body>
  <style is:global>
    /* In regular site view, hide stats placeholder */
    .stats-placeholder {
      display: none !important;
    }
    
    /* In Sanity CMS Presentation iframe view, display stats placeholder */
    html.sanity-preview-mode .stats-placeholder {
      display: block !important;
    }
  </style>
</html>
