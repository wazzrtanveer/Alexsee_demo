---
import Layout from '../../layouts/Layout.astro';
import { frames, settings } from '../../data/mockData.js';

export function getStaticPaths() {
  return frames.map(frame => ({
    params: { id: frame.id },
    props: { frame },
  }));
}

const { frame } = Astro.props;
const others = frames.filter(f => f.id !== frame.id).slice(0, 2);
---

<Layout
  title={`${frame.brand} — ${frame.model} | AlexSEE Paris`}
  description={frame.description}
>
  <div id="frame-detail-view-root" class="pt-28 pb-24 bg-ivory text-optical-black min-h-screen px-6 md:px-12 lg:px-24">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-10 border-b border-stone-grey/15 pb-6">
      <a href="/collections" class="group flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-widest text-stone-grey hover:text-optical-black transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        <span>Retour au lookbook</span>
      </a>
      <span class="text-stone-grey/40 font-mono text-[9px]">/</span>
      <span class="font-mono text-[9px] uppercase tracking-widest text-stone-grey">Modèle : {frame.brand} — {frame.model}</span>
    </div>

    <!-- Main grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-stretch">
      <!-- Image column -->
      <div class="col-span-1 lg:col-span-7 flex flex-col gap-6">
        <div class="aspect-[4/5] bg-stone-light/40 relative overflow-hidden border border-stone-grey/15">
          <!-- Main display image (toggleable) -->
          <img
            id="detail-img"
            src={frame.images[0]}
            alt={`${frame.brand} view`}
            referrerpolicy="no-referrer"
            class="w-full h-full object-cover absolute inset-0 transition-opacity duration-500"
          />
          <!-- View toggles -->
          <div class="absolute bottom-6 left-6 flex gap-2 z-10">
            {['[ Vue Objet ]', '[ Vue Portée ]'].map((label, i) => (
              <button
                data-view-idx={i}
                data-img-src={frame.images[i]}
                class={`view-toggle-btn font-mono text-[9px] uppercase tracking-widest py-1.5 px-3 border transition-colors ${i === 0 ? 'bg-optical-black text-ivory border-optical-black' : 'bg-ivory/80 text-optical-black border-stone-grey/25 backdrop-blur-sm'}`}
              >
                {label}
              </button>
            ))}
          </div>
        </div>
        <p class="font-mono text-[9px] text-stone-grey uppercase tracking-wider text-center">
          * Photos non contractuelles. Essayages recommandés directement en boutique.
        </p>
      </div>

      <!-- Details column -->
      <div class="col-span-1 lg:col-span-5 flex flex-col justify-between space-y-8">
        <div class="space-y-6">
          <!-- Brand + Model -->
          <div>
            <span class="font-mono text-[10px] tracking-widest text-stone-grey uppercase block mb-1">{frame.brand}</span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-light uppercase tracking-tight" style="font-family: var(--font-display);">{frame.model}</h1>
          </div>

          <!-- Price + badge -->
          <div class="flex items-center gap-4">
            <span class="font-mono text-xl tracking-tight font-medium text-cobalt">{frame.price}</span>
            <span class="h-4 w-[1px] bg-stone-grey/30"></span>
            <div class="inline-flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-wider text-emerald-600 bg-emerald-50 px-2 py-0.5">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
              <span>Selectionneur créateur</span>
            </div>
          </div>

          <!-- Description -->
          <div class="space-y-4">
            <p class="font-sans text-stone-grey text-md leading-relaxed font-light">{frame.description}</p>
            {frame.designerPhilosophy && (
              <div class="border-l-2 border-cobalt pl-4 py-1 italic font-serif text-sm text-optical-black">
                « {frame.designerPhilosophy} »
              </div>
            )}
          </div>

          <!-- Specs table -->
          <div class="border-t border-b border-stone-grey/20 py-4 space-y-2.5 font-mono text-xs text-stone-grey">
            <div class="flex justify-between">
              <span>Matière :</span><span class="text-optical-black font-semibold uppercase">{frame.material}</span>
            </div>
            <div class="flex justify-between">
              <span>Couleur :</span><span class="text-optical-black font-semibold uppercase">{frame.color}</span>
            </div>
            <div class="flex justify-between">
              <span>Calibre / Pont / Branche :</span>
              <span class="text-optical-black">{frame.specs.lensWidth} ▢ {frame.specs.bridgeWidth} — {frame.specs.templeLength} mm</span>
            </div>
            <div class="flex justify-between items-center">
              <span>Disponibilité :</span>
              <div class="inline-flex items-center gap-1.5 font-semibold text-optical-black">
                <span class={`w-1.5 h-1.5 rounded-full ${frame.availability === 'En boutique' ? 'bg-emerald-500' : 'bg-amber-500'}`}></span>
                <span>{frame.availability}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="space-y-3 pt-4">
          <a
            href={`/contact?frame=${encodeURIComponent(frame.brand + ' - ' + frame.model)}`}
            class="w-full bg-cobalt hover:bg-optical-black text-ivory text-center py-4 text-xs font-mono font-semibold tracking-widest uppercase transition-colors duration-300 shadow-md flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span>Essayer ce modèle en boutique Paris 20</span>
          </a>
          <a
            href={`mailto:${settings.email}?subject=Demande de disponibilité : ${encodeURIComponent(frame.brand + ' - ' + frame.model)}`}
            class="w-full border border-optical-black/25 hover:border-cobalt text-optical-black hover:text-cobalt text-center py-4 text-xs font-mono tracking-widest uppercase transition-colors duration-300 block bg-transparent"
          >
            Demander la disponibilité à distance
          </a>
        </div>

        <!-- Boutique info box -->
        <div class="bg-stone-light/40 p-4 border border-stone-grey/10 text-xs text-stone-grey space-y-1 font-mono">
          <span class="font-semibold text-optical-black uppercase tracking-wider block text-[9px]">Venir en boutique</span>
          <p>{settings.address}, {settings.postalCode} {settings.city}</p>
          <p>{settings.metro}</p>
          <a href={`tel:${settings.phone.replace(/\s+/g,'')}`} class="text-cobalt hover:underline">{settings.phone}</a>
        </div>
      </div>
    </div>

    <!-- Other frames -->
    {others.length > 0 && (
      <div class="mt-24 border-t border-stone-grey/15 pt-16">
        <h2 class="text-2xl font-light uppercase tracking-tight mb-10" style="font-family: var(--font-display);">Autres Montures</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
          {others.map(other => (
            <a href={`/frame/${other.id}`} class="group flex gap-5 items-center border border-stone-grey/15 p-4 hover:border-cobalt transition-colors duration-300">
              <div class="w-24 h-24 bg-stone-light/40 overflow-hidden flex-shrink-0">
                <img src={other.images[0]} alt={other.model} referrerpolicy="no-referrer" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div>
                <span class="font-mono text-[9px] uppercase tracking-wider text-stone-grey block">{other.brand}</span>
                <h3 class="text-xl font-light uppercase tracking-tight group-hover:text-cobalt transition-colors" style="font-family: var(--font-display);">{other.model}</h3>
                <span class="font-mono text-sm text-cobalt">{other.price}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  function initFrameDetail() {
    const img = document.getElementById('detail-img');
    const toggleBtns = document.querySelectorAll('.view-toggle-btn');
    if (!img || !toggleBtns.length) return;

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-img-src');
        if (src && img instanceof HTMLImageElement) {
          img.style.opacity = '0';
          setTimeout(() => {
            img.src = src;
            img.style.opacity = '1';
          }, 250);
        }
        // Update active button styles
        toggleBtns.forEach(b => {
          b.classList.remove('bg-optical-black', 'text-ivory', 'border-optical-black');
          b.classList.add('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');
        });
        btn.classList.add('bg-optical-black', 'text-ivory', 'border-optical-black');
        btn.classList.remove('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');
      });
    });
  }

  document.addEventListener('astro:page-load', initFrameDetail);
</script>
