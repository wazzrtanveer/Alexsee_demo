---
import Layout from '../../layouts/Layout.astro';
import { frames, settings } from '../../data/mockData.js';

export function getStaticPaths() {
  return frames.map(frame => ({
    params: { id: frame.id },
    props: { frame },
  }));
}

const { frame } = Astro.props;
const others = frames.filter(f => f.id !== frame.id).slice(0, 2);
---

<Layout
  title={`${frame.brand} — ${frame.model} | AlexSEE Paris`}
  description={frame.description}
>
  <div id="frame-detail-view-root" class="pt-28 pb-24 bg-ivory text-optical-black min-h-screen px-6 md:px-12 lg:px-24">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-10 border-b border-stone-grey/15 pb-6">
      <a href="/collections" class="group flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-widest text-[#7B7973] hover:text-[#0D0D0E] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        <span>Retour au lookbook</span>
      </a>
      <span class="text-stone-grey/40 font-mono text-[9px] font-light select-none">/</span>
      <span class="font-mono text-[9px] uppercase tracking-widest text-stone-grey">Modèle : {frame.brand} — {frame.model}</span>
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-stretch">
      <!-- Left Column: Image & View Toggle -->
      <div class="col-span-1 lg:col-span-7 flex flex-col gap-6">
        <div class="aspect-[4/5] bg-stone-light/40 relative overflow-hidden border border-stone-grey/15">
          <!-- Images -->
          {frame.images.map((src, i) => (
            <img
              id={`detail-img-${i}`}
              src={src}
              alt={`${frame.brand} view`}
              referrerpolicy="no-referrer"
              class={`w-full h-full object-cover absolute inset-0 transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
            />
          ))}
          <!-- View Toggles -->
          <div class="absolute bottom-6 left-6 flex gap-2 z-10">
            <button id="toggle-view-0" class="view-toggle-btn font-mono text-[9px] uppercase tracking-widest py-1.5 px-3 border transition-colors bg-optical-black text-ivory border-optical-black">
              [ Vue Objet ]
            </button>
            <button id="toggle-view-1" class="view-toggle-btn font-mono text-[9px] uppercase tracking-widest py-1.5 px-3 border transition-colors bg-ivory/80 text-optical-black border-stone-grey/25 backdrop-blur-sm">
              [ Vue Portée ]
            </button>
          </div>
        </div>
        <p class="font-mono text-[9px] text-[#7B7973] uppercase tracking-wider text-center">
          * Photos non contractuelles. Essayages recommandés directement en boutique.
        </p>
      </div>

      <!-- Right Column: Specs & Actions -->
      <div class="col-span-1 lg:col-span-5 flex flex-col justify-between space-y-8">
        <div class="space-y-6">
          <div>
            <span class="font-mono text-[10px] tracking-widest text-[#7B7973] uppercase block mb-1">{frame.brand}</span>
            <h1 style="font-family: var(--font-display);" class="text-4xl md:text-5xl lg:text-6xl font-light uppercase tracking-tight text-optical-black">{frame.model}</h1>
          </div>

          <div class="flex items-center gap-4">
            <span class="font-mono text-xl tracking-tight font-medium text-cobalt">{frame.price}</span>
            <span class="h-4 w-[1px] bg-stone-grey/30"></span>
            <div class="inline-flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-wider text-emerald-600 bg-emerald-50 px-2 py-0.5">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
              <span>Selectionneur créateur</span>
            </div>
          </div>

          <div class="space-y-4">
            <p class="font-sans text-stone-grey text-md leading-relaxed font-light">{frame.description}</p>
            {frame.designerPhilosophy && (
              <div class="border-l-2 border-cobalt pl-4 py-1 italic font-serif text-sm text-optical-black">
                « {frame.designerPhilosophy} »
              </div>
            )}
          </div>

          <div class="border-t border-b border-stone-grey/20 py-4 space-y-2.5 font-mono text-xs text-stone-grey">
            <div class="flex justify-between">
              <span>Matière :</span>
              <span class="text-optical-black font-semibold uppercase">{frame.material}</span>
            </div>
            <div class="flex justify-between">
              <span>Couleur :</span>
              <span class="text-optical-black font-semibold uppercase">{frame.color}</span>
            </div>
            <div class="flex justify-between">
              <span>Calibre / Pont / Branche :</span>
              <span class="text-optical-black">{frame.specs.lensWidth} ▢ {frame.specs.bridgeWidth} — {frame.specs.templeLength} mm</span>
            </div>
            <div class="flex justify-between items-center">
              <span>Disponibilité :</span>
              <div class="inline-flex items-center gap-1.5 font-semibold text-optical-black">
                <span class={`w-1.5 h-1.5 rounded-full ${frame.availability === 'En boutique' ? 'bg-emerald-500' : 'bg-amber-500'}`}></span>
                <span>{frame.availability}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="space-y-3 pt-4">
          <a
            href={`/contact?frame=${encodeURIComponent(frame.brand + ' - ' + frame.model)}`}
            class="w-full bg-cobalt hover:bg-optical-black text-ivory text-center py-4 text-xs font-mono font-semibold tracking-widest uppercase transition-colors duration-300 shadow-md shadow-cobalt/10 flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span>Essayer ce modèle en boutique Paris 20</span>
          </a>
          <a
            href={`mailto:${settings.email}?subject=Demande de disponibilité : ${encodeURIComponent(frame.brand + ' - ' + frame.model)}`}
            class="w-full border border-optical-black/25 hover:border-cobalt text-optical-black hover:text-cobalt text-center py-4 text-xs font-mono tracking-widest uppercase transition-colors duration-300 block bg-transparent"
          >
            Demander la disponibilité à distance
          </a>
        </div>

        <!-- Info box -->
        <div class="bg-stone-light/40 p-4 border border-stone-grey/10 text-xs text-stone-grey space-y-1">
          <p class="font-mono text-[9px] uppercase text-stone-grey tracking-wider flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Atelier AlexSEE Paris
          </p>
          <p class="font-sans">28 Rue d’Avron, 75020 Paris. Métro Buzenval (M9).</p>
          <p class="font-sans text-[11px] text-stone-grey/80 font-light">
            Notre équipe d’opticiens procède à l’essayage personnalisé et à la prise de vos mesures de centrage d’art.
          </p>
        </div>
      </div>
    </div>

    <!-- Related frames -->
    {others.length > 0 && (
      <div class="mt-24 border-t border-stone-grey/25 pt-12">
        <h2 class="text-stone-grey font-mono text-[10px] uppercase tracking-widest block mb-8">[ Modèles d’art apparentés ]</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {others.map(other => (
            <a href={`/frame/${other.id}`} class="flex items-center gap-6 p-4 border border-stone-grey/15 hover:border-cobalt bg-ivory transition-all duration-300 cursor-pointer group">
              <div class="w-24 h-24 bg-stone-light/40 overflow-hidden relative border border-stone-light shrink-0">
                <img src={other.images[0]} alt={other.model} referrerpolicy="no-referrer" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="space-y-1">
                <span class="font-mono text-[8px] uppercase tracking-wider text-stone-grey block">{other.brand}</span>
                <span style="font-family: var(--font-display);" class="text-lg uppercase text-optical-black group-hover:text-cobalt transition-colors font-medium">{other.model}</span>
                <span class="font-mono text-xs text-stone-grey block">{other.material} — {other.price}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  function setupFrameDetail() {
    const toggle0 = document.getElementById('toggle-view-0');
    const toggle1 = document.getElementById('toggle-view-1');
    const img0 = document.getElementById('detail-img-0');
    const img1 = document.getElementById('detail-img-1');

    if (!toggle0 || !toggle1 || !img0 || !img1) return;

    toggle0.addEventListener('click', () => {
      img0.classList.replace('opacity-0', 'opacity-100');
      img1.classList.replace('opacity-100', 'opacity-0');
      
      toggle0.classList.add('bg-optical-black', 'text-ivory', 'border-optical-black');
      toggle0.classList.remove('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');

      toggle1.classList.remove('bg-optical-black', 'text-ivory', 'border-optical-black');
      toggle1.classList.add('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');
    });

    toggle1.addEventListener('click', () => {
      img0.classList.replace('opacity-100', 'opacity-0');
      img1.classList.replace('opacity-0', 'opacity-100');

      toggle1.classList.add('bg-optical-black', 'text-ivory', 'border-optical-black');
      toggle1.classList.remove('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');

      toggle0.classList.remove('bg-optical-black', 'text-ivory', 'border-optical-black');
      toggle0.classList.add('bg-ivory/80', 'text-optical-black', 'border-stone-grey/25', 'backdrop-blur-sm');
    });
  }

  let cleanup;
  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = setupFrameDetail();
  });
</script>
