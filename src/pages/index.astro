    </section>

    <!-- ── Notre Philosophie ── -->
    <section id="intro-philosophy-section" class="py-24 md:py-36 px-6 md:px-12 lg:px-24 bg-optical-black text-ivory relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="col-span-1 lg:col-span-8">
          <span data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'philosophySectionHeader' }) : undefined} class="font-mono text-[10px] tracking-[0.3em] uppercase text-stone-grey block mb-6">{home.philosophySectionHeader || "[ 01 / Notre Philosophie ]"}</span>
          <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'philosophyQuote' }) : undefined} style="font-family: var(--font-display);" class="text-4xl md:text-6xl font-light tracking-tight leading-tight">
            {home.philosophyQuote ? (
              home.philosophyQuote.includes('\n') ? (
                home.philosophyQuote.split('\n').map((line, i) => (
                  <>
                    {i === 1 ? (
                      <span class="text-cobalt font-medium italic">{line}</span>
                    ) : (
                      line
                    )}
                    {i < home.philosophyQuote.split('\n').length - 1 && <br />}
                  </>
                ))
              ) : (
                home.philosophyQuote
              )
            ) : (
              <>
                « Chez AlexSEE, une monture ne complète pas simplement un visage.<br/>
                <span class="text-cobalt font-medium italic">Elle révèle une attitude. »</span>
              </>
            )}
          </p>
        </div>
        <div class="col-span-1 lg:col-span-4 space-y-6">
          <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'philosophySubtext' }) : undefined} class="font-sans text-stone-grey text-md leading-relaxed">
            {home.philosophySubtext || "Nous sélectionnons des collections nées d’ateliers indépendants, où le design n’est jamais standardisé. Ici, pas de logos clinquants ni de montures industrielles. Nous privilégions la finesse des plaques d’acétate japonaises, la rigueur constructive du titane brut et la sincérité d’un conseil d’opticien expert."}
          </p>
          <a href="/boutique" data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'philosophyLinkText' }) : undefined} class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-ivory hover:text-cobalt transition-colors duration-300">
            <span>{home.philosophyLinkText || "Visiter notre atelier rue d’Avron"}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Featured Eyewear (Créations Phares) ── -->
    <section id="featured-eyewear-section" class="py-24 md:py-36 px-6 md:px-12 lg:px-24 bg-ivory">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 border-b border-stone-grey/20 pb-8">
        <div>
          <span data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'featuredSectionHeader' }) : undefined} class="font-mono text-[10px] tracking-[0.25em] text-stone-grey uppercase block mb-3">{home.featuredSectionHeader || "[ 02 / Créations phares ]"}</span>
