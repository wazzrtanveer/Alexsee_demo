        </div>
      </div>

      <!-- Mobile layout -->
      <div class="flex lg:hidden flex-col w-full text-left gap-6 pb-4">
        <div class="flex flex-col">
          <div class="mb-4 inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-cobalt rounded-full animate-pulse"></span>
            <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroBadgeText' }) : undefined} class="font-mono text-[9px] tracking-widest text-cobalt uppercase font-bold">{home.heroBadgeText || "Boutique indépendante de créateurs"}</p>
          </div>
          <h1 data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroHeadline' }) : undefined} class="text-[48px] sm:text-[68px] font-normal leading-[0.9] tracking-tight text-optical-black mb-4" style="font-family: var(--font-display);">
            {firstLine}
            {secondLine && (
              <>
                <br />
                <span class="italic ml-6 sm:ml-12 text-cobalt block">{secondLine}</span>
              </>
            )}
          </h1>
        </div>
        <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroSubtext' }) : undefined} class="font-sans text-optical-black/95 text-base font-light mb-2 max-w-xl leading-relaxed">
          {home.heroSubtext || "Montures de caractère, conseils personnalisés et savoir-faire optique au cœur du 20ème arrondissement."}
        </p>
        <div data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroImage' }) : undefined} class="relative w-full aspect-[4/5] bg-[#EAE5DF] overflow-hidden border border-stone-grey/15 mt-2">
          <img src={urlFor(home.heroImage) || "/assets/alexsee_hero_man_1781887423927-Daa6PeCv.jpg"} alt="Portrait éditorial AlexSEE" referrerpolicy="no-referrer" class="w-full h-full object-cover" />

          <div class="absolute top-4 left-4 bg-optical-black/85 text-ivory text-[8px] font-mono uppercase tracking-widest px-2 py-1 border border-white/10">Édition Limitée</div>
