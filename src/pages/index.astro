---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import { sanityClient, FRAMES_QUERY, SERVICES_QUERY, SETTINGS_QUERY, urlFor, dataAttribute, cleanStega } from '../lib/sanity.js';
import { frames as mockFrames, services as mockServices, settings as mockSettings } from '../data/mockData.js';

let frames = [];
let services = [];
let settings = mockSettings;

try {
  const sanityFrames = await sanityClient.fetch(FRAMES_QUERY);
  if (sanityFrames && sanityFrames.length > 0) {
    frames = sanityFrames;
  } else {
    frames = mockFrames;
  }
} catch (e) {
  console.error("Error fetching frames from Sanity, using mock data:", e);
  frames = mockFrames;
}

try {
  const sanityServices = await sanityClient.fetch(SERVICES_QUERY);
  if (sanityServices && sanityServices.length > 0) {
    services = sanityServices;
  } else {
    services = mockServices;
  }
} catch (e) {
  console.error("Error fetching services from Sanity, using mock data:", e);
  services = mockServices;
}

try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings from Sanity, using mock data:", e);
}

const featuredFrames = frames.filter(f => f.isFeatured);
---

<Layout
  title="AlexSEE — Opticien Créateur Paris 20e"
  description="Boutique d'optique indépendante à Paris 20e. Découvrez notre vestiaire de lunettes de créateurs."
>

  <div id="homepage-container" class="pt-24 bg-ivory text-optical-black overflow-x-hidden relative">
    <!-- Decorative blurs -->
    <div class="absolute top-[-100px] left-[-100px] w-[400px] h-[400px] bg-[#2E5BFF] rounded-full blur-[180px] opacity-[0.03] pointer-events-none"></div>
    <div class="absolute bottom-[20%] right-[-50px] w-[300px] h-[300px] bg-stone-grey rounded-full blur-[150px] opacity-[0.05] pointer-events-none"></div>

    <!-- ── Hero ── -->
    <section id="hero-section" data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'heroHeadline' }) : undefined} class="relative min-h-[90vh] flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-12 overflow-hidden border-b border-stone-grey/10">
      <div class="absolute top-1/4 right-1/4 w-[50vw] h-[50vw] rounded-full bg-cobalt/5 blur-[120px] pointer-events-none"></div>
      <div class="absolute inset-y-0 left-1/3 w-[1px] bg-stone-light/40 pointer-events-none hidden lg:block"></div>
      <div class="absolute inset-y-0 left-2/3 w-[1px] bg-stone-light/40 pointer-events-none hidden lg:block"></div>

      <!-- Vertical label -->
      <div class="absolute left-6 lg:left-10 bottom-32 text-[10px] tracking-[0.3em] uppercase text-stone-grey hidden md:block select-none font-mono" style="writing-mode: vertical-rl; text-orientation: mixed; transform: rotate(180deg);">
        Opticien Créateur — Paris 20e
      </div>

      <!-- Desktop layout -->
      <div class="hidden lg:flex flex-row justify-between items-stretch gap-16 relative z-10 w-full pt-12">
        <!-- Left column -->
        <div class="w-[52%] flex flex-col justify-between pr-4">
          <div>
            <div class="mb-6 inline-flex items-center gap-2">
              <span class="w-2 h-2 bg-cobalt rounded-full animate-pulse"></span>
              <p class="font-mono text-[10px] tracking-widest text-cobalt uppercase font-bold">Boutique indépendante de créateurs</p>
            </div>
            <h1 class="text-[64px] lg:text-[100px] xl:text-[112px] font-normal leading-[0.85] tracking-tight text-optical-black mb-10" style="font-family: var(--font-display);">
              {settings.heroHeadline ? (
                settings.heroHeadline.includes('\n') ? (
                  settings.heroHeadline.split('\n').map((line, idx) => (
                    <>
                      {line}
                      {idx < settings.heroHeadline.split('\n').length - 1 && <br />}
                    </>
                  ))
                ) : (
                  settings.heroHeadline
                )
              ) : (
                <>
                  Voir<br />
                  <span class="italic ml-16 text-cobalt block">autrement.</span>
                </>
              )}
            </h1>
            <p class="font-sans text-optical-black/90 text-lg xl:text-xl font-light mb-10 max-w-xl leading-relaxed">
              {settings.heroSubtext || "Montures de caractère, conseils personnalisés et savoir-faire optique au cœur du 20ème arrondissement. Une signature visuelle authentique."}
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/collections" id="hero-cta-collection" data-cursor-label="EXPLORER" class="group flex items-center gap-3 bg-optical-black text-ivory hover:bg-cobalt px-8 py-4 transition-all duration-300 tracking-widest font-mono text-xs uppercase">
                <span>Découvrir la sélection</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-2 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href="/contact" id="hero-cta-contact" class="group flex items-center gap-2 border border-optical-black/30 hover:border-cobalt px-8 py-4 text-optical-black hover:text-cobalt bg-transparent transition-all duration-300 font-mono text-xs uppercase tracking-widest">
                <span>Prendre rendez-vous</span>
                <span class="font-mono font-bold text-cobalt text-[9px] select-none">●</span>
              </a>
            </div>
          </div>
          <div class="mt-14 pt-8 border-t border-stone-grey/25 flex flex-col gap-4 font-mono text-[10px] uppercase tracking-wider text-stone-grey">
            <div class="flex items-center gap-8">
              <a href={`tel:${cleanStega(settings.phone).replace(/\s+/g, '')}`} class="flex items-center gap-2 hover:text-cobalt group transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt animate-pulse"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.58 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10a16 16 0 0 0 6 6l.72-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>Téléphone : <strong class="text-optical-black font-medium group-hover:underline">{settings.phone}</strong></span>
              </a>
              <a href="https://maps.google.com/?q=28+Rue+d'Avron,+75020+Paris" target="_blank" rel="noreferrer" class="flex items-center gap-2 hover:text-cobalt group transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Itinéraire : <strong class="text-optical-black font-medium group-hover:underline">{settings.address}, Paris 20e</strong></span>
              </a>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>Horaires d'ouverture : <strong class="text-optical-black font-medium">9h30 - 13h00, 14h00 - 19h30 (Mar-Sam)</strong></span>
            </div>
          </div>
        </div>

        <!-- Right column — interactive magnifier lens -->
        <div class="w-[44%] flex flex-col gap-6 justify-between relative pl-4">
          <div id="hero-img-container" class="relative w-full aspect-[4/5] bg-[#EAE5DF] overflow-hidden border border-stone-grey/15 shadow-sm cursor-crosshair select-none group">
            <img
              id="hero-main-img"
              src={urlFor(settings.heroImage) || "https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1000&q=80"}
              alt="Portrait éditorial AlexSEE"
              referrerpolicy="no-referrer"
              class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-[1.01]"
              style="transform: scale(1.03); opacity: 0;"
            />
            <div class="absolute left-0 top-0 h-full w-20 bg-gradient-to-r from-ivory to-transparent pointer-events-none z-10"></div>
            <div class="absolute inset-0 border border-double border-white/10 m-3 pointer-events-none z-10"></div>

            <!-- Lens magnifier element -->
            <div id="lens-circle" class="absolute w-32 h-32 md:w-36 md:h-36 rounded-full border border-cobalt/40 overflow-hidden shadow-2xl bg-[#EAE5DF] backdrop-blur-[1px] pointer-events-none z-20" style="left: 75%; top: 65%; transform: translate(-50%, -50%); transition: left 0.8s cubic-bezier(0.16,1,0.3,1), top 0.8s cubic-bezier(0.16,1,0.3,1);">
              <div class="absolute inset-0 bg-cobalt/[0.03] z-10"></div>
              <div class="absolute top-1/2 left-4 right-4 h-[1px] bg-cobalt/20 -translate-y-1/2 z-10"></div>
              <div class="absolute left-1/2 top-4 bottom-4 w-[1px] bg-cobalt/20 -translate-x-1/2 z-10"></div>
              <img id="lens-inner-img" src={urlFor(settings.heroImage) || "https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1000&q=80"} alt="" referrerpolicy="no-referrer" class="absolute max-w-none pointer-events-none select-none origin-center" style="width: 450px; height: 560px; left: -300px; top: -320px; transform: scale(1.22);" />
              <span class="absolute bottom-2 left-1/2 -translate-x-1/2 bg-optical-black text-ivory text-[7px] font-mono uppercase tracking-widest px-1.5 py-0.5 z-20 border border-white/10 whitespace-nowrap">VERRE ACCORD 1.2x</span>
            </div>
            <div class="absolute top-4 left-4 bg-optical-black/85 text-ivory text-[8px] font-mono uppercase tracking-widest px-2 py-1 border border-white/10 z-10">Édition Limitée</div>
          </div>

          <div class="flex justify-between items-start font-mono text-[10px] uppercase tracking-wider text-stone-grey px-1 leading-relaxed">
            <div class="text-left">
              <span class="block text-optical-black font-semibold tracking-widest">{settings.name}</span>
              <span class="block text-stone-grey/85 mt-0.5">{settings.address}</span>
              <span class="block text-stone-grey/85">{settings.postalCode} {settings.city}</span>
            </div>
            <div class="text-right text-stone-grey/75 leading-relaxed">
              <span>Atelier Lunetterie</span>
              <span class="block text-[9px] font-light mt-1 text-cobalt">[ Opticien Créateur ]</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile layout -->
      <div class="flex lg:hidden flex-col w-full text-left gap-6 pb-4">
        <div class="flex flex-col">
          <div class="mb-4 inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-cobalt rounded-full animate-pulse"></span>
            <p class="font-mono text-[9px] tracking-widest text-cobalt uppercase font-bold">Boutique indépendante de créateurs</p>
          </div>
          <h1 class="text-[48px] sm:text-[68px] font-normal leading-[0.9] tracking-tight text-optical-black mb-4" style="font-family: var(--font-display);">
            Voir<br />
            <span class="italic ml-6 sm:ml-12 text-cobalt block">autrement.</span>
          </h1>
        </div>
        <p class="font-sans text-optical-black/95 text-base font-light mb-2 max-w-xl leading-relaxed">
          Montures de caractère, conseils personnalisés et savoir-faire optique au cœur du 20ème arrondissement.
        </p>
        <div class="relative w-full aspect-[4/5] bg-[#EAE5DF] overflow-hidden border border-stone-grey/15 mt-2">
          <img src={urlFor(settings.heroImage) || "https://images.unsplash.com/photo-1574258495973-f010dfbb5371?auto=format&fit=crop&w=1000&q=80"} alt="Portrait éditorial AlexSEE" referrerpolicy="no-referrer" class="w-full h-full object-cover" />
          <div class="absolute top-4 left-4 bg-optical-black/85 text-ivory text-[8px] font-mono uppercase tracking-widest px-2 py-1 border border-white/10">Édition Limitée</div>
          <!-- Mobile Lens -->
          <div class="absolute w-24 h-24 rounded-full border border-cobalt/40 bg-cobalt/[0.03] backdrop-blur-[1px] bottom-[10%] right-[10%] overflow-hidden pointer-events-none z-10">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-[1px] h-8 bg-cobalt/20"></div>
              <div class="h-[1px] w-8 bg-cobalt/20"></div>
            </div>
            <div class="absolute bottom-1.5 right-1/2 translate-x-1/2 text-[6px] font-mono tracking-widest text-cobalt uppercase font-bold text-center">LENS 1.2</div>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 mt-4 w-full">
          <a href="/collections" class="flex items-center justify-center gap-3 bg-optical-black text-ivory hover:bg-cobalt px-6 py-4 transition-all duration-300 tracking-widest font-mono text-xs uppercase w-full">
            <span>Découvrir la sélection</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="flex items-center justify-center gap-2 border border-optical-black/30 hover:border-cobalt px-6 py-4 text-optical-black hover:text-cobalt bg-transparent transition-all duration-300 font-mono text-xs uppercase tracking-widest w-full">
            <span>Prendre rendez-vous</span>
          </a>
        </div>
        <div class="mt-4 pt-4 border-t border-stone-grey/25 flex flex-col gap-3 font-mono text-[10px] uppercase tracking-wider text-stone-grey/95">
          <a href={`tel:${cleanStega(settings.phone).replace(/\s+/g, '')}`} class="flex items-center gap-2.5 py-1 hover:text-cobalt transition-colors min-h-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.58 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10a16 16 0 0 0 6 6l.72-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>Appeler : <strong class="text-optical-black font-semibold">{settings.phone}</strong></span>
          </a>
          <a href="https://maps.google.com/?q=28+Rue+d'Avron,+75020+Paris" target="_blank" rel="noreferrer" class="flex items-center gap-2.5 py-1 hover:text-cobalt transition-colors min-h-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Itinéraire : <strong class="text-optical-black font-semibold">{settings.address}, Paris 20e</strong></span>
          </a>
          <div class="flex items-start gap-2.5 py-1 min-h-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cobalt mt-0.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="leading-relaxed">Horaires : <strong class="text-optical-black font-semibold block sm:inline">9h30 - 13h00, 14h00 - 19h30 (Mar-Sam)</strong></span>
          </div>
        </div>
        <div class="text-[8.5px] font-mono uppercase text-stone-grey/75 mt-2">
          <span>{settings.name} optique — Paris 20e — {settings.unconfirmedNote}</span>
        </div>
      </div>
    </section>

    <!-- ── Notre Philosophie ── -->
    <section id="intro-philosophy-section" class="py-24 md:py-36 px-6 md:px-12 lg:px-24 bg-optical-black text-ivory relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="col-span-1 lg:col-span-8">
          <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-stone-grey block mb-6">[ 01 / Notre Philosophie ]</span>
          <p style="font-family: var(--font-display);" class="text-4xl md:text-6xl font-light tracking-tight leading-tight">
            {settings.philosophyQuote ? (
              settings.philosophyQuote.includes('\n') ? (
                settings.philosophyQuote.split('\n').map((line, i) => (
                  <>
                    {i === 1 ? (
                      <span class="text-cobalt font-medium italic">{line}</span>
                    ) : (
                      line
                    )}
                    {i < settings.philosophyQuote.split('\n').length - 1 && <br />}
                  </>
                ))
              ) : (
                settings.philosophyQuote
              )
            ) : (
              <>
                « Chez AlexSEE, une monture ne complète pas simplement un visage.<br/>
                <span class="text-cobalt font-medium italic">Elle révèle une attitude. »</span>
              </>
            )}
          </p>
        </div>
        <div class="col-span-1 lg:col-span-4 space-y-6">
          <p class="font-sans text-stone-grey text-md leading-relaxed">
            {settings.philosophySubtext || "Nous sélectionnons des collections nées d’ateliers indépendants, où le design n’est jamais standardisé. Ici, pas de logos clinquants ni de montures industrielles. Nous privilégions la finesse des plaques d’acétate japonaises, la rigueur constructive du titane brut et la sincérité d’un conseil d’opticien expert."}
          </p>
          <a href="/boutique" class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-ivory hover:text-cobalt transition-colors duration-300">
            <span>{settings.philosophyLinkText || "Visiter notre atelier rue d’Avron"}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Featured Eyewear (Créations Phares) ── -->
    <section id="featured-eyewear-section" class="py-24 md:py-36 px-6 md:px-12 lg:px-24 bg-ivory">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 border-b border-stone-grey/20 pb-8">
        <div>
          <span class="font-mono text-[10px] tracking-[0.25em] text-stone-grey uppercase block mb-3">[ 02 / Créations phares ]</span>
          <h2 style="font-family: var(--font-display);" class="text-4xl md:text-5xl font-light tracking-tight uppercase">{settings.featuredTitle || "Le regard dessiné"}</h2>
        </div>
        <a href="/collections" data-cursor-label="LOOKBOOK" class="mt-6 md:mt-0 inline-flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-[#0D0D0E] hover:text-cobalt font-medium transition-colors">
          <span>{settings.featuredLinkText || "Voir toute la collection"} ({frames.length} modèles)</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
        {featuredFrames.map((frame, idx) => (
          <a href={`/frame/${cleanStega(frame.id)}`} data-sanity={frame._id ? dataAttribute({ id: frame._id, type: frame._type }) : undefined} data-cursor-label="VOIR" class={`flex flex-col justify-between group cursor-pointer ${idx === 1 ? 'md:translate-y-12' : idx === 2 ? 'md:translate-y-6' : ''}`}>
            <div class="aspect-[3/4] bg-stone-light/40 relative overflow-hidden mb-6 border border-stone-grey/10">
              {frame.isNew && <span class="absolute top-4 left-4 z-10 bg-cobalt text-ivory font-mono text-[8px] uppercase tracking-widest py-1 px-2.5">Nouveauté</span>}
              <img src={urlFor(frame.images[0])} alt={`${frame.brand} ${frame.model}`} referrerpolicy="no-referrer" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-in-out pointer-events-none">
                <img src={urlFor(frame.images[1])} alt={`${frame.brand} model study`} referrerpolicy="no-referrer" class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-700 ease-out" />
                <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-ivory/10 to-transparent mix-blend-overlay"></div>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <div class="flex items-baseline justify-between">
                <span class="font-mono text-[9px] uppercase tracking-wider text-stone-grey">{frame.brand}</span>
                <span class="font-mono text-[10px] tracking-normal text-stone-grey">{frame.price}</span>
              </div>
              <h3 style="font-family: var(--font-display);" class="text-2xl font-light uppercase tracking-tight group-hover:text-cobalt transition-colors duration-300">{frame.model}</h3>
              <p class="text-xs text-stone-grey/90 line-clamp-2 leading-relaxed">{frame.description}</p>
              <div class="mt-4 flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-widest text-[#0D0D0E] group-hover:text-cobalt transition-colors">
                <span>Détails & Disponibilité</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="translate-x-0 group-hover:translate-x-1.5 transition-transform"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Manifeste AlexSEE ── -->
    <section id="manifesto-section" class="py-24 md:py-36 bg-ivory border-t border-b border-stone-grey/20 relative">
      <div class="absolute inset-0 opacity-5 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full border border-optical-black w-[40vw] h-[40vw] animate-lens-pulse"></div>
      </div>
