                <span>Itinéraire : <strong data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'address' }) : undefined} class="text-optical-black font-medium group-hover:underline">{settings.address}, Paris 20e</strong></span>
              </a>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cobalt"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>Horaires d'ouverture : <strong data-sanity={settings._id ? dataAttribute({ id: settings._id, type: settings._type, path: 'heroHoursText' }) : undefined} class="text-optical-black font-medium">{settings.heroHoursText || "9h30 - 13h00, 14h00 - 19h30 (Mar-Sam)"}</strong></span>
            </div>
          </div>
        </div>

        <!-- Right column — interactive magnifier lens -->
        <div class="w-[36%] flex flex-col gap-6 justify-between relative pl-4">
          <div id="hero-img-container" data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroImage' }) : undefined} class="relative w-full aspect-[4/5] bg-[#EAE5DF] overflow-hidden border border-stone-grey/15 shadow-sm cursor-crosshair select-none group">
            <img
              id="hero-main-img"
              src={urlFor(home.heroImage) || "/assets/alexsee_hero_man_1781887423927-Daa6PeCv.jpg"}
