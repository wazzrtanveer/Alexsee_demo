<script>
  function initHero() {
    const container = document.getElementById('hero-img-container');
    const mainImg = document.getElementById('hero-main-img');
    const lens = document.getElementById('lens-circle');
    const lensImg = document.getElementById('lens-inner-img');
    if (!container || !lens || !lensImg || !mainImg) return;

    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const xPct = (e.clientX - rect.left) / rect.width * 100;
      const yPct = (e.clientY - rect.top) / rect.height * 100;

      lens.style.transition = 'none';
      lens.style.left = `${xPct}%`;
      lens.style.top = `${yPct}%`;

      const w = rect.width;
      const h = rect.height;
      lensImg.style.transition = 'none';
      lensImg.style.width = `${w}px`;
      lensImg.style.height = `${h}px`;
      lensImg.style.left = `-${xPct / 100 * w}px`;
      lensImg.style.top = `-${yPct / 100 * h}px`;
    });

    container.addEventListener('mouseleave', () => {
      lens.style.transition = 'left 0.8s cubic-bezier(0.16,1,0.3,1), top 0.8s cubic-bezier(0.16,1,0.3,1)';
      lens.style.left = '75%';
      lens.style.top = '65%';
      lensImg.style.transition = 'all 0.8s cubic-bezier(0.16,1,0.3,1)';
      lensImg.style.left = '-300px';
      lensImg.style.top = '-320px';
    });
  }

  document.addEventListener('astro:page-load', initHero);
</script>
