              <div class="absolute inset-0 bg-cobalt/[0.03] z-10"></div>
              <div class="absolute top-1/2 left-4 right-4 h-[1px] bg-cobalt/20 -translate-y-1/2 z-10"></div>
              <div class="absolute left-1/2 top-4 bottom-4 w-[1px] bg-cobalt/20 -translate-x-1/2 z-10"></div>
              <img id="lens-inner-img" src={urlFor(home.heroImage) || "/assets/alexsee_hero_man_1781887423927-Daa6PeCv.jpg"} alt="" referrerpolicy="no-referrer" class="absolute max-w-none pointer-events-none select-none origin-center" style="width: 450px; height: 560px; left: -300px; top: -320px; transform: scale(1.22); transition: 0.8s cubic-bezier(0.16, 1, 0.3, 1);" />
              <span class="absolute bottom-2 left-1/2 -translate-x-1/2 bg-optical-black text-ivory text-[7px] font-mono uppercase tracking-widest px-1.5 py-0.5 z-20 border border-white/10 whitespace-nowrap">VERRE ACCORD 1.2x</span>
