                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-2 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href="/contact" id="hero-cta-contact" class="group flex items-center gap-2 border border-optical-black/30 hover:border-cobalt px-8 py-4 text-optical-black hover:text-cobalt bg-transparent transition-all duration-300 font-mono text-xs uppercase tracking-widest">
