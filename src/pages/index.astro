---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import { sanityClient, FRAMES_QUERY, SERVICES_QUERY, SETTINGS_QUERY, PAGE_HOME_QUERY, urlFor, dataAttribute, cleanStega } from '../lib/sanity.js';
import { frames as mockFrames, services as mockServices, settings as mockSettings } from '../data/mockData.js';

let frames = [];
let services = [];
let settings = mockSettings;
let pageHome = null;

try {
  const sanityFrames = await sanityClient.fetch(FRAMES_QUERY);
  if (sanityFrames && sanityFrames.length > 0) {
    frames = sanityFrames;
  } else {
    frames = mockFrames;
  }
} catch (e) {
  console.error("Error fetching frames from Sanity, using mock data:", e);
  frames = mockFrames;
}

try {
  const sanityServices = await sanityClient.fetch(SERVICES_QUERY);
  if (sanityServices && sanityServices.length > 0) {
    services = sanityServices;
  } else {
    services = mockServices;
  }
} catch (e) {
  console.error("Error fetching services from Sanity, using mock data:", e);
  services = mockServices;
}

try {
  const sanitySettings = await sanityClient.fetch(SETTINGS_QUERY);
  if (sanitySettings) {
    settings = { ...mockSettings, ...sanitySettings };
  }
} catch (e) {
  console.error("Error fetching settings from Sanity, using mock data:", e);
}

try {
  const sanityPageHome = await sanityClient.fetch(PAGE_HOME_QUERY);
  if (sanityPageHome) {
    pageHome = sanityPageHome;
  }
} catch (e) {
  console.error("Error fetching pageHome from Sanity:", e);
}

const home = pageHome || {
  ...settings,
  _id: 'pageHome',
  _type: 'pageHome'
};

const headlineRaw = home.heroHeadline || "Voir\nautrement.";
const hasNewline = cleanStega(headlineRaw).includes('\n');
const spaceIdx = cleanStega(headlineRaw).indexOf(' ');

let firstLine = "Voir";
let secondLine = "autrement.";

if (hasNewline) {
  const parts = headlineRaw.split('\n');
  firstLine = parts[0];
  secondLine = parts.slice(1).join('\n');
} else if (spaceIdx > -1) {
  firstLine = headlineRaw.substring(0, spaceIdx); 
  secondLine = headlineRaw.substring(spaceIdx + 1);
} else {
  firstLine = headlineRaw;
  secondLine = "";
}
const rawFeatured = frames.filter(f => f.isFeatured);
const rawNonFeatured = frames.filter(f => !f.isFeatured);

const tempFeatured = [...rawFeatured];
const includedIds = new Set(tempFeatured.map(f => cleanStega(f.id || f._id)));

// Add Sanity non-featured frames if we have fewer than 3
for (const frame of rawNonFeatured) {
  if (tempFeatured.length >= 3) break;
  const cleanId = cleanStega(frame.id || frame._id);
  if (cleanId && !includedIds.has(cleanId)) {
    tempFeatured.push(frame);
    includedIds.add(cleanId);
  }
}

// Fallback to mock featured frames
for (const mockFrame of mockFrames) {
  if (tempFeatured.length >= 3) break;
  if (mockFrame.isFeatured && !includedIds.has(mockFrame.id)) {
    tempFeatured.push(mockFrame);
    includedIds.add(mockFrame.id);
  }
}

// Fallback to mock non-featured frames
for (const mockFrame of mockFrames) {
  if (tempFeatured.length >= 3) break;
  if (!includedIds.has(mockFrame.id)) {
    tempFeatured.push(mockFrame);
    includedIds.add(mockFrame.id);
  }
}

const featuredFrames = tempFeatured.slice(0, 3);
---


<Layout
  seoTitle={home.seo?.seoTitle}
  seoDescription={home.seo?.seoDescription}
  seoImage={home.seo?.seoImage}
  title="AlexSEE — Opticien Créateur Paris 20e"
  description="Boutique d'optique indépendante à Paris 20e. Découvrez notre vestiaire de lunettes de créateurs."
