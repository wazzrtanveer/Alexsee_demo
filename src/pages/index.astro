              <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroBadgeText' }) : undefined} class="font-mono text-[10px] tracking-widest text-cobalt uppercase font-bold">{home.heroBadgeText || "Boutique indépendante de créateurs"}</p>
            </div>
            <h1 data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroHeadline' }) : undefined} class="text-[64px] lg:text-[100px] xl:text-[112px] font-normal leading-[0.85] tracking-tight text-optical-black mb-10" style="font-family: var(--font-display);">
              {firstLine}
              {secondLine && (
                <>
                  <br />
                  <span class="italic ml-16 text-cobalt block">{secondLine}</span>
                </>
              )}
