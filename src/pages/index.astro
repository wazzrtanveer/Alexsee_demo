            <p data-sanity={home._id ? dataAttribute({ id: home._id, type: home._type, path: 'heroSubtext' }) : undefined} class="font-sans text-optical-black/90 text-lg xl:text-xl font-light mb-10 max-w-xl leading-relaxed">
              {home.heroSubtext || "Montures de caractère, conseils personnalisés et savoir-faire optique au cœur du 20ème arrondissement. Une signature visuelle authentique."}
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/collections" id="hero-cta-collection" data-cursor-label="EXPLORER" class="group flex items-center gap-3 bg-optical-black text-ivory hover:bg-cobalt px-8 py-4 transition-all duration-300 tracking-widest font-mono text-xs uppercase">
