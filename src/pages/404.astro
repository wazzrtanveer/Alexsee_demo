---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Axe de réfraction perdu | AlexSEE Paris"
  description="Cette page est introuvable. Recentrons votre vision."
>
  <div id="notfound-root" class="pt-36 pb-24 bg-ivory text-optical-black min-h-screen px-6 md:px-12 lg:px-24 flex flex-col items-center justify-center relative overflow-hidden">
    <!-- Decorative background rings -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70vw] h-[70vw] rounded-full border border-stone-grey/15 flex items-center justify-center p-3 pointer-events-none mix-blend-difference">
      <div class="w-[50vw] h-[50vw] rounded-full border border-dashed border-cobalt/25 animate-[spin_120s_linear_infinite]"></div>
    </div>

    <!-- Main Content Container -->
    <div class="max-w-xl text-center space-y-8 relative z-10">
      <!-- Giant 404 text with lens overlay -->
      <div class="relative inline-block overflow-hidden py-4">
        <h1 style="font-family: var(--font-display);" class="text-8xl md:text-9xl font-bold tracking-widest text-[#0D0D0E]/10 select-none text-stroke text-optical-black text-center transition-all duration-[1500ms] tracking-[0.15em] filter blur-[0.5px]">
          404
        </h1>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 rounded-full border border-cobalt mix-blend-screen pointer-events-none flex items-center justify-center backdrop-blur-sm">
          <span class="font-mono text-[10px] tracking-widest text-cobalt uppercase font-bold animate-pulse">
            Axe de réfraction
          </span>
        </div>
      </div>

      <!-- Error Wording -->
      <div class="space-y-3">
        <span class="font-mono text-[10px] tracking-[0.25em] text-cobalt uppercase block">
          [ Le regard s’égare — Erreur d’axe ]
        </span>
        <h2 style="font-family: var(--font-display);" class="text-2xl md:text-3xl font-light uppercase tracking-tight text-optical-black">
          Point focal hors-champ
        </h2>
        <p class="font-sans text-stone-grey text-sm max-w-sm mx-auto leading-relaxed">
          La perspective recherchée n’est pas disponible dans le catalogue de l’atelier. Recentrons votre vision.
        </p>
      </div>

      <!-- Action buttons -->
      <div class="pt-6 flex flex-col sm:flex-row justify-center gap-3">
        <a href="/" class="bg-optical-black hover:bg-cobalt text-ivory font-mono text-xs uppercase tracking-widest py-3.5 px-6 transition-colors duration-300 inline-flex items-center gap-2 justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="5" y1="12" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span>Revenir à l’accueil</span>
        </a>
        <a href="/collections" class="border border-stone-grey/30 hover:border-optical-black text-optical-black font-mono text-xs uppercase tracking-widest py-3.5 px-6 transition-colors duration-300 inline-flex items-center gap-2 justify-center bg-transparent">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" x2="12" y1="22.08" y2="12"/></svg>
          <span>Découvrir le catalogue</span>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
